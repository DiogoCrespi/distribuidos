<mxfile host="app.diagrams.net" pages="1">
  <diagram id="whatsut_collaboration" name="Collaboration Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="co WhatsUT RMI - Diagrama de Colaboração (Solicitação, Aprovação e Mensagem)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=550;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1050" height="720" as="geometry" />
        </mxCell>
        
        <!-- Objects (Nodes) -->
        
        <!-- obj_clienteA (Active Object - Requester) -->
        <mxCell id="obj_clienteA" value="&lt;u&gt;A:ClienteUI&lt;/u&gt;&lt;br&gt;(Solicitante)" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="220" width="140" height="70" as="geometry" />
        </mxCell>
        
        <!-- obj_server (Passive/Service Object - RMI Server) -->
        <mxCell id="obj_server" value="&lt;u&gt;s:WhatsUTServerImpl&lt;/u&gt;&lt;br&gt;(Servidor RMI)" style="whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="220" width="170" height="70" as="geometry" />
        </mxCell>
        
        <!-- obj_clienteB (Active Object - Admin) -->
        <mxCell id="obj_clienteB" value="&lt;u&gt;B:ClienteUI&lt;/u&gt;&lt;br&gt;(Admin do Grupo)" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="220" width="150" height="70" as="geometry" />
        </mxCell>
        
        <!-- Notes Box -->
        <mxCell id="note_rmicallback" value="&lt;b&gt;Fluxo do Diagrama de Colaboração (Java RMI com Callbacks):&lt;/b&gt;&lt;br&gt;1. &lt;b&gt;Solicitação de Entrada:&lt;/b&gt; Cliente A chama &lt;i&gt;pedirEntradaGrupo&lt;/i&gt; no Servidor RMI.&lt;br&gt;2. &lt;b&gt;Callback de Permissão:&lt;/b&gt; O Servidor localiza o Admin do grupo (Cliente B) e dispara a chamada de callback &lt;i&gt;pedirPermissaoGrupo&lt;/i&gt; utilizando a referência remota do stub de B.&lt;br&gt;3. &lt;b&gt;Resposta do Admin:&lt;/b&gt; Cliente B responde ao servidor via &lt;i&gt;responderEntradaGrupo(..., true)&lt;/i&gt;.&lt;br&gt;4. &lt;b&gt;Notificação &amp; Atualização:&lt;/b&gt; O Servidor inclui A nos membros do grupo e faz um callback &lt;i&gt;notificar&lt;/i&gt; para o Cliente A informando o sucesso.&lt;br&gt;5. &lt;b&gt;Envio de Mensagem Autenticado:&lt;/b&gt; Cliente A agora é membro e envia uma mensagem. O servidor valida a associação antes de repassar a mensagem aos demais membros (como Cliente B) via callback &lt;i&gt;receberMensagem&lt;/i&gt;. Se um não-membro tentar enviar, o Servidor rejeita e lança &lt;i&gt;RemoteException&lt;/i&gt;." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="480" height="230" as="geometry" />
        </mxCell>
        
        <!-- Legend Box -->
        <mxCell id="note_legend" value="&lt;b&gt;Legenda de Cores e Fluxo:&lt;/b&gt;&lt;br&gt;- &lt;font color=&quot;#d79b00&quot;&gt;&lt;b&gt;Laranja:&lt;/b&gt;&lt;/font&gt; Cliente Solicitante A.&lt;br&gt;- &lt;font color=&quot;#6c8ebf&quot;&gt;&lt;b&gt;Azul:&lt;/b&gt;&lt;/font&gt; Servidor Central RMI.&lt;br&gt;- &lt;font color=&quot;#9673a6&quot;&gt;&lt;b&gt;Roxo:&lt;/b&gt;&lt;/font&gt; Cliente Administrador B.&lt;br&gt;- &lt;b&gt;Links Sólidos (linhas):&lt;/b&gt; Canais de conexão RMI.&lt;br&gt;- &lt;b&gt;Direção das Mensagens:&lt;/b&gt;&lt;br&gt;  - &lt;b&gt;⟶ :&lt;/b&gt; Chamada RMI no sentido de A/B para Servidor.&lt;br&gt;  - &lt;b&gt;⟵ :&lt;/b&gt; Chamada RMI Callback do Servidor para A/B.&lt;br&gt;- &lt;b&gt;[Validação de Segurança]:&lt;/b&gt; Adicionada no servidor para checar membro antes de retransmitir mensagens." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="470" width="410" height="230" as="geometry" />
        </mxCell>
        
        <!-- Edges (Links with Messages) -->
        
        <!-- Link 1: Cliente A to Server (pedirEntrada, notificar, enviarMensagemGrupo, Exception) -->
        <mxCell id="edge_A_server" edge="1" parent="1" source="obj_clienteA" target="obj_server" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_A_server" connectable="0" parent="edge_A_server" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="1: pedirEntradaGrupo(grupo, de) ⟶&lt;br&gt;1.3: notificar(&quot;Aprovado!&quot;) ⟵&lt;br&gt;2: enviarMensagemGrupo(de, grupo, txt) ⟶&lt;br&gt;[Validação de Segurança: throws RemoteException] ⟵" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-5" y="-45" as="offset" />
          </mxGeometry>
        </mxCell>
        
        <!-- Link 2: Server to Cliente B (pedirPermissao, responderEntrada, receberMensagem) -->
        <mxCell id="edge_server_B" edge="1" parent="1" source="obj_server" target="obj_clienteB" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_server_B" connectable="0" parent="edge_server_B" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="1.1: pedirPermissaoGrupo(grupo, de) ⟶&lt;br&gt;1.2: responderEntradaGrupo(..., true) ⟵&lt;br&gt;2.1: receberMensagem(msg) ⟶" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="5" y="-35" as="offset" />
          </mxGeometry>
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
