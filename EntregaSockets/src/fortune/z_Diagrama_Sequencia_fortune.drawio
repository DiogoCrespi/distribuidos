<mxfile host="app.diagrams.net" pages="1">
  <diagram id="fortune_sequence" name="Sequence Diagram">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="sd Fortune Cookies" style="shape=umlFrame;whiteSpace=wrap;html=1;width=120;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="730" height="580" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lifeline_cliente" value=":Cliente" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="120" y="80" width="100" height="480" as="geometry" />
        </mxCell>
        <mxCell id="act_cliente" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="390" as="geometry" />
        </mxCell>
        <mxCell id="act_print_res" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="50" y="360" width="10" height="40" as="geometry" />
        </mxCell>

        <mxCell id="lifeline_servidor" value=":Servidor" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="520" y="80" width="100" height="480" as="geometry" />
        </mxCell>
        <mxCell id="act_servidor" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="45" y="100" width="10" height="300" as="geometry" />
        </mxCell>
        <mxCell id="act_process_cmd" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="50" y="170" width="10" height="60" as="geometry" />
        </mxCell>

        <!-- Loop Frame for Game operations -->
        <mxCell id="loop_frame" value="loop" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="50" y="130" width="670" height="380" as="geometry" />
        </mxCell>
        
        <mxCell id="txt_loop_cond" value="[enquanto opcao != &quot;0&quot;]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="50" y="145" width="150" height="20" as="geometry" />
        </mxCell>

        <!-- Messages -->
        <mxCell id="msg_connect" value="1: Conectar Socket (new Socket)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="175" y="180" as="sourcePoint" />
            <mxPoint x="575" y="180" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_send" value="1.1: Enviar comando (ex: GET-FORTUNE)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="175" y="220" as="sourcePoint" />
            <mxPoint x="575" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_process" value="1.2: processarComando()" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_process_cmd">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="250" />
              <mxPoint x="590" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_process_ret" value="" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_process_cmd" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="310" as="sourcePoint" />
            <mxPoint x="575" y="310" as="targetPoint" />
            <Array as="points">
              <mxPoint x="590" y="310" />
              <mxPoint x="590" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_response" value="1.3: Retornar resposta (String)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="575" y="380" as="sourcePoint" />
            <mxPoint x="175" y="380" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_close" value="1.4: Fechar Socket (socket.close())" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="175" y="420" as="sourcePoint" />
            <mxPoint x="575" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_print" value="1.5: Exibir resposta" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_print_res">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="190" y="440" />
              <mxPoint x="190" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>