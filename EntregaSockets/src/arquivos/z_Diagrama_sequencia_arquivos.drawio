<mxfile host="app.diagrams.net" pages="1">
  <diagram id="arquivos_sequence" name="Sequence Diagram">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="sd FileTransfer" style="shape=umlFrame;whiteSpace=wrap;html=1;width=120;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="850" height="720" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lifeline_cliente" value=":Cliente" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="120" y="80" width="100" height="600" as="geometry" />
        </mxCell>
        <mxCell id="act_cliente" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="500" as="geometry" />
        </mxCell>

        <mxCell id="lifeline_servidor" value=":Servidor" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="420" y="80" width="100" height="600" as="geometry" />
        </mxCell>
        <mxCell id="act_servidor" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="500" as="geometry" />
        </mxCell>

        <mxCell id="lifeline_armazenamento" value=":Armazenamento" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="720" y="80" width="100" height="600" as="geometry" />
        </mxCell>
        <mxCell id="act_armazenamento" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lifeline_armazenamento" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="500" as="geometry" />
        </mxCell>

        <!-- Login flow messages -->
        <mxCell id="msg_connect" value="1: Conectar &amp; Enviar LOGIN(user, senha)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="170" as="sourcePoint" />
            <mxPoint x="460" y="170" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="act_auth_self" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="50" y="100" width="10" height="40" as="geometry" />
        </mxCell>
        <mxCell id="msg_auth" value="1.1: autenticar(user, pass)" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;entryX=1;entryY=0;" edge="1" parent="lifeline_servidor" source="act_servidor" target="act_auth_self">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="90" />
              <mxPoint x="80" y="100" />
            </Array>
            <mxPoint x="55" y="90" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_login_res" value="1.2: Retorno (SUCESSO / ERRO)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="240" as="sourcePoint" />
            <mxPoint x="180" y="240" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Operation Alt Frame -->
        <mxCell id="op_alt" value="alt" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="60" y="270" width="790" height="420" as="geometry" />
        </mxCell>
        
        <mxCell id="txt_cond_upload" value="[operação == UPLOAD]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="60" y="280" width="130" height="20" as="geometry" />
        </mxCell>

        <!-- UPLOAD Flow -->
        <mxCell id="msg_upload" value="2: UPLOAD(nome, tamanho, bytes)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="330" as="sourcePoint" />
            <mxPoint x="460" y="330" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg_upload_save" value="2.1: gravarArquivo(usuario, nome, bytes)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_armazenamento">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="360" as="sourcePoint" />
            <mxPoint x="760" y="360" as="targetPoint" />
            <Array as="points">
              <mxPoint x="620" y="360" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg_upload_res" value="2.2: SUCESSO: Arquivo recebido" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="410" as="sourcePoint" />
            <mxPoint x="180" y="410" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Alt Frame Divider -->
        <mxCell id="alt_divider" value="" style="endArrow=none;dashed=1;html=1;rounded=0;exitX=0;exitY=0.45;exitDx=0;exitDy=0;exitPerimeter=0;entryX=1;entryY=0.45;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="op_alt" target="op_alt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <mxCell id="txt_cond_download" value="[operação == DOWNLOAD]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="60" y="470" width="150" height="20" as="geometry" />
        </mxCell>

        <!-- DOWNLOAD Flow -->
        <mxCell id="msg_download" value="3: DOWNLOAD(nome)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="510" as="sourcePoint" />
            <mxPoint x="460" y="510" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg_download_read" value="3.1: lerArquivo(usuario, nome)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_armazenamento">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="540" as="sourcePoint" />
            <mxPoint x="760" y="540" as="targetPoint" />
            <Array as="points">
              <mxPoint x="620" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg_download_res" value="3.2: Retorno (tamanho, bytes ou -1)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="590" as="sourcePoint" />
            <mxPoint x="180" y="590" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="590" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="act_client_save_self" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="50" y="530" width="10" height="30" as="geometry" />
        </mxCell>
        <mxCell id="msg_client_save" value="3.3: salvarLocal(baixado_nome)" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;entryX=1;entryY=0;" edge="1" parent="lifeline_cliente" source="act_cliente" target="act_client_save_self">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="520" />
              <mxPoint x="80" y="530" />
            </Array>
            <mxPoint x="55" y="520" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
