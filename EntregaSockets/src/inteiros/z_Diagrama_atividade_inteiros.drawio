<mxfile host="app.diagrams.net" pages="1">
  <diagram id="inteiros_activity" name="Activity Diagram">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Swimlanes for Client and Server -->
        <mxCell id="swimlanes" value="Processamento de Inteiros" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="760" height="1100" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_cliente" value="Cliente (ClienteInteiros.java)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="370" height="1080" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_servidor" value="Servidor (ServidorInteiros.java)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="390" y="20" width="370" height="1080" as="geometry" />
        </mxCell>

        <!-- CLIENT FLOW -->
        <mxCell id="act_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_cliente">
          <mxGeometry x="170" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="act_open_socket" value="Abrir Socket (porta 12346)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="100" y="100" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_show_prompt" value="Exibir instruções de entrada" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="95" y="180" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_read_input" value="Ler entrada do usuário" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="260" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_send_input" value="Enviar entrada ao Servidor" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="340" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_is_op" value="input == &quot;SOMA&quot; || &quot;MULT&quot;?" style="rhombus;" vertex="1" parent="lane_cliente">
          <mxGeometry x="85" y="420" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_shutdown_output" value="Fechar Output Stream (socket.shutdownOutput())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="65" y="530" width="240" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_read_response" value="Ler resposta do Servidor" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="610" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_print_response" value="Exibir resultado no console" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="690" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_close_socket" value="Fechar Socket" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_cliente">
          <mxGeometry x="125" y="770" width="120" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_end_client" value="End" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_cliente">
          <mxGeometry x="170" y="850" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- SERVER FLOW -->
        <mxCell id="act_srv_init" value="Aguardar conexão (accept)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="100" y="100" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_srv_setup" value="Inicializar numeros = List&lt;Integer&gt;&#xa;operacao = &quot;SOMA&quot;" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="75" y="180" width="220" height="45" as="geometry" />
        </mxCell>

        <mxCell id="act_srv_read" value="Ler linha do Cliente" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="260" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_srv_eof" value="linha == null (EOF)?" style="rhombus;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="340" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="dec_is_number" value="É número (parseInt)?" style="rhombus;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="440" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_add_number" value="Adicionar número à lista" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="15" y="530" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_set_op" value="operacao = linha.toUpperCase()" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_servidor">
          <mxGeometry x="195" y="530" width="165" height="40" as="geometry" />
        </mxCell>

        <mxCell id="merge_read_loop" value="" style="rhombus;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="170" y="610" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="dec_op" value="operacao == &quot;MULT&quot;?" style="rhombus;" vertex="1" parent="lane_servidor">
          <mxGeometry x="100" y="700" width="170" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_calc_mult" value="Multiplicar todos os números" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="15" y="790" width="160" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_calc_soma" value="Somar todos os números" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="195" y="790" width="160" height="40" as="geometry" />
        </mxCell>

        <mxCell id="merge_calc" value="" style="rhombus;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="170" y="870" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="act_srv_send_resp" value="Enviar resposta com o resultado" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="85" y="930" width="200" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_srv_close" value="Fechar Socket do Cliente" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="1000" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- EDGES WITH parent="1" -->

        <!-- Client: Start -> Open Socket -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_start" target="act_open_socket">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Open Socket -> Show Prompt -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_open_socket" target="act_show_prompt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Show Prompt -> Read Input -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_show_prompt" target="act_read_input">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Read Input -> Send Input -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_read_input" target="act_send_input">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Send Input -> Dec Is Op -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_send_input" target="dec_is_op">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Dec Is Op -> Read Input (No) -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="dec_is_op" target="act_read_input" value="Não">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="450" />
              <mxPoint x="80" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Client: Dec Is Op -> Shutdown Output (Yes) -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_is_op" target="act_shutdown_output" value="Sim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Shutdown Output -> Read Response -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_shutdown_output" target="act_read_response">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Read Response -> Print Response -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_read_response" target="act_print_response">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Print Response -> Close Socket -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_print_response" target="act_close_socket">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client: Close Socket -> End -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_close_socket" target="act_end_client">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Init -> Setup -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_srv_init" target="act_srv_setup">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Setup -> Read Line -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_srv_setup" target="act_srv_read">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Read Line -> Dec EOF -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_srv_read" target="dec_srv_eof">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Dec EOF -> Dec Is Number (No) -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_srv_eof" target="dec_is_number" value="Não">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Dec Is Number -> Add Number (Yes) -->
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_is_number" target="act_add_number" value="Sim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Dec Is Number -> Set Op (No) -->
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_is_number" target="act_set_op" value="Não">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Add Number -> Merge Read Loop -->
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_add_number" target="merge_read_loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Set Op -> Merge Read Loop -->
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_set_op" target="merge_read_loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Merge Read Loop -> Read Line (Loop back) -->
        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="merge_read_loop" target="act_srv_read">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="625" />
              <mxPoint x="380" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Server: Dec EOF -> Dec Op (Yes) -->
        <mxCell id="e21" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="dec_srv_eof" target="dec_op" value="Sim">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="360" y="370" />
              <mxPoint x="360" y="670" />
              <mxPoint x="185" y="670" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Server: Dec Op -> Calc Mult (MULT) -->
        <mxCell id="e22" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_op" target="act_calc_mult" value="MULT">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Dec Op -> Calc Soma (SOMA) -->
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_op" target="act_calc_soma" value="SOMA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Calc Mult -> Merge Calc -->
        <mxCell id="e24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_calc_mult" target="merge_calc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Calc Soma -> Merge Calc -->
        <mxCell id="e25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_calc_soma" target="merge_calc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Merge Calc -> Send Resp -->
        <mxCell id="e26" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="merge_calc" target="act_srv_send_resp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Send Resp -> Close Socket -->
        <mxCell id="e27" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_srv_send_resp" target="act_srv_close">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server: Close Socket -> Loop back to accept -->
        <mxCell id="e28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="act_srv_close" target="act_srv_init">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="780" y="1020" />
              <mxPoint x="780" y="120" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- NETWORK COMMUNICATIONS (Dashed Edges) -->

        <!-- Client: Open Socket - - > Server: Init (Connection) -->
        <mxCell id="e_conn" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_open_socket" target="act_srv_init">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="120" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Client: Send Input - - > Server: Read Line -->
        <mxCell id="e_send" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_send_input" target="act_srv_read">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="360" />
              <mxPoint x="320" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Client: Shutdown Output (EOF) - - > Server: Dec EOF -->
        <mxCell id="e_eof" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_shutdown_output" target="dec_srv_eof">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="550" />
              <mxPoint x="330" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Server: Send Resp - - > Client: Read Response -->
        <mxCell id="e_resp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_srv_send_resp" target="act_read_response">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="950" />
              <mxPoint x="330" y="630" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>