<mxfile host="app.diagrams.net" pages="1">
  <diagram id="inteiros_sequence" name="Sequence Diagram">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="sd Processamento de Inteiros" style="shape=umlFrame;whiteSpace=wrap;html=1;width=200;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="730" height="660" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lifeline_cliente" value=":Cliente" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="120" y="80" width="100" height="560" as="geometry" />
        </mxCell>
        <mxCell id="act_cliente" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="470" as="geometry" />
        </mxCell>
        <mxCell id="act_read_user" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="50" y="150" width="10" height="30" as="geometry" />
        </mxCell>
        <mxCell id="act_print_res" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="50" y="440" width="10" height="30" as="geometry" />
        </mxCell>

        <mxCell id="lifeline_servidor" value=":Servidor" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="520" y="80" width="100" height="560" as="geometry" />
        </mxCell>
        <mxCell id="act_servidor" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="45" y="90" width="10" height="450" as="geometry" />
        </mxCell>
        <mxCell id="act_srv_parse" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="50" y="220" width="10" height="30" as="geometry" />
        </mxCell>
        <mxCell id="act_process" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="50" y="350" width="10" height="40" as="geometry" />
        </mxCell>

        <!-- Loop Frame for User Inputs -->
        <mxCell id="loop_frame" value="loop" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="50" y="210" width="670" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="txt_loop_cond" value="[enquanto scanner.hasNext()]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="50" y="225" width="170" height="20" as="geometry" />
        </mxCell>

        <!-- Messages -->
        
        <!-- 1: Connect -->
        <mxCell id="msg_connect" value="1: Conectar Socket (new Socket)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="175" y="170" as="sourcePoint" />
            <mxPoint x="575" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Inside loop -->
        <!-- 2: Read input -->
        <mxCell id="msg_read" value="2: Ler input (ex: &quot;10&quot; ou &quot;SOMA&quot;)" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_read_user">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="190" y="235" />
              <mxPoint x="190" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 2.1: Send to server -->
        <mxCell id="msg_send" value="2.1: Enviar linha pelo socket" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="175" y="300" as="sourcePoint" />
            <mxPoint x="575" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 2.2: Parse line / update state -->
        <mxCell id="msg_parse" value="2.2: parse/add ou set operacao" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_srv_parse">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="305" />
              <mxPoint x="590" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Outside loop -->
        <!-- 3: Shutdown output (EOF) -->
        <mxCell id="msg_shutdown" value="3: Fechar output stream (socket.shutdownOutput())" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="175" y="415" as="sourcePoint" />
            <mxPoint x="575" y="415" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 4: Process results -->
        <mxCell id="msg_process" value="4: processar(numeros, operacao)" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_process">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="435" />
              <mxPoint x="590" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 5: Return result -->
        <mxCell id="msg_response" value="5: Retornar resultado (String)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="575" y="505" as="sourcePoint" />
            <mxPoint x="175" y="505" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 6: Print response -->
        <mxCell id="msg_print" value="6: Exibir resposta" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_print_res">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="190" y="525" />
              <mxPoint x="190" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>