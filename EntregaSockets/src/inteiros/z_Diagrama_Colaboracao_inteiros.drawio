<mxfile host="app.diagrams.net" pages="1">
  <diagram id="inteiros_collaboration" name="Collaboration Diagram">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="co Processamento de Inteiros via Sockets (Diagrama de Colaboração)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=410;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="800" height="520" as="geometry" />
        </mxCell>

        <!-- Objects (Nodes) -->
        
        <!-- cliente : Cliente (Active Object - terminal interface) -->
        <mxCell id="obj_cliente" value="&lt;u&gt;cliente : Cliente&lt;/u&gt;" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="220" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- servidor : Servidor (Active Object - operations processor) -->
        <mxCell id="obj_servidor" value="&lt;u&gt;servidor : Servidor&lt;/u&gt;" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="220" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Note Box: Concurrency & Sockets notes -->
        <mxCell id="note_concurrency" value="&lt;b&gt;Comunicação Orientada a Stream (shutdownOutput):&lt;/b&gt;&lt;br&gt;- &lt;b&gt;cliente:&lt;/b&gt; Envia inteiros sequencialmente e finaliza enviando a operação. Em seguida, executa &lt;i&gt;shutdownOutput()&lt;/i&gt;, sinalizando EOF (fim de arquivo) para o servidor, e aguarda o resultado.&lt;br&gt;- &lt;b&gt;servidor:&lt;/b&gt; Lê as linhas até atingir o EOF (retorno nulo do Stream). Então executa &lt;i&gt;processar()&lt;/i&gt; e envia a resposta final pelo socket.&lt;br&gt;- &lt;b&gt;Operações Suportadas:&lt;/b&gt; SOMA (padrão) ou MULT (multiplicação de todos os elementos recebidos)." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="320" height="140" as="geometry" />
        </mxCell>

        <!-- Legend Box -->
        <mxCell id="note_legend" value="&lt;b&gt;Legenda de Cores e Estereótipos:&lt;/b&gt;&lt;br&gt;- &lt;font color=&quot;#d79b00&quot;&gt;&lt;b&gt;Laranja:&lt;/b&gt;&lt;/font&gt; Classe Ativa Cliente (Console de Entrada)&lt;br&gt;- &lt;font color=&quot;#6c8ebf&quot;&gt;&lt;b&gt;Azul:&lt;/b&gt;&lt;/font&gt; Classe Ativa Servidor (Processador de Operações)&lt;br- &gt;- &lt;b&gt;Setas Sólidas:&lt;/b&gt; Chamadas Síncronas / Escrita no Socket TCP&lt;br&gt;- &lt;b&gt;Setas Tracejadas:&lt;/b&gt; Retornos de dados e respostas de rede&lt;br&gt;- &lt;b&gt;Self-Loops:&lt;/b&gt; Operações locais da aplicação." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="360" width="320" height="140" as="geometry" />
        </mxCell>

        <!-- Edges (Links with Messages) -->

        <!-- self-call: cliente (ler input, exibir) -->
        <mxCell id="edge_cliente_self" edge="1" parent="1" source="obj_cliente" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fontSize=12;strokeColor=#d79b00;strokeWidth=1.5;" target="obj_cliente">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="170" />
              <mxPoint x="240" y="170" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_cliente_self" connectable="0" parent="edge_cliente_self" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="2: Ler input (ex: '10', 'SOMA')&lt;br&gt;6: Exibir resposta" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-20" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 1: cliente to servidor (connect, send, shutdown calls) -->
        <mxCell id="edge_cliente_servidor" edge="1" parent="1" source="obj_cliente" target="obj_servidor" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#d79b00;fillColor=#ffe6cc;exitX=1;exitY=0.3;entryX=0;entryY=0.3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_cliente_servidor" connectable="0" parent="edge_cliente_servidor" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="1: Conectar Socket (new Socket)&lt;br&gt;2.1: Enviar linha pelo socket&lt;br&gt;3: Fechar output stream (shutdown)" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-22" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 1 Return: servidor to cliente (responses) -->
        <mxCell id="edge_cliente_servidor_ret" edge="1" parent="1" source="obj_servidor" target="obj_cliente" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#d79b00;fillColor=#ffe6cc;dashed=1;endArrow=open;exitX=0;exitY=0.7;entryX=1;entryY=0.7;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_cliente_servidor_ret" connectable="0" parent="edge_cliente_servidor_ret" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="5: Retornar resultado (String)" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- self-call: servidor (parse, process) -->
        <mxCell id="edge_servidor_self" edge="1" parent="1" source="obj_servidor" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fontSize=12;strokeColor=#6c8ebf;strokeWidth=1.5;" target="obj_servidor">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="510" y="170" />
              <mxPoint x="570" y="170" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_servidor_self" connectable="0" parent="edge_servidor_self" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="2.2: parse/add ou set operacao&lt;br&gt;4: processar(numeros, operacao)" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-20" as="offset" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
