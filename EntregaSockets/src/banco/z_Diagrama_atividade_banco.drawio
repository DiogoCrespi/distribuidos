        <!-- CMD: DEPOSITO -->
        <mxCell id="act_srv_dep" value="Adicionar valor e retornar SUCESSO" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="10" y="700" width="110" height="40" as="geometry" />
        </mxCell>

        <!-- CMD: SAQUE -->
        <mxCell id="dec_saque_ok" value="Saldo suficiente?" style="rhombus;" vertex="1" parent="lane_servidor">
          <mxGeometry x="130" y="760" width="110" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_saque_ok" value="Subtrair valor e retornar SUCESSO" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
