<mxfile host="app.diagrams.net" pages="1">
  <diagram id="banco_activity" name="Activity Diagram">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Swimlanes for Client and Server -->
        <mxCell id="swimlanes" value="Sistema Bancário" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="760" height="960" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_cliente" value="Cliente (ClienteBanco.java)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="370" height="940" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_servidor" value="Servidor (ServidorBanco.java)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="390" y="20" width="370" height="940" as="geometry" />
        </mxCell>

        <!-- CLIENT FLOW -->
        <mxCell id="act_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_cliente">
          <mxGeometry x="170" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="act_connect" value="Conectar ao Servidor (localhost:12348)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="100" y="90" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_read_welcome" value="Ler boas-vindas do Servidor" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="160" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_send_acc" value="Solicitar conta ao usuário e enviar" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="100" y="230" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- SERVER FLOW -->
        <mxCell id="act_welcome_msg" value="Apresentar boas-vindas e pedir conta" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="100" y="90" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_recv_acc" value="Receber número da conta" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="230" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_acc_exists" value="Conta Existe?" style="rhombus;" vertex="1" parent="lane_servidor">
          <mxGeometry x="135" y="300" width="100" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_srv_err" value="Enviar mensagem de erro e encerrar" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_servidor">
          <mxGeometry x="220" y="390" width="140" height="40" as="geometry" />
        </mxCell>

        <!-- CLIENT AUTH RESPONSE -->
        <mxCell id="dec_client_auth" value="Conexão encerrada?" style="rhombus;" vertex="1" parent="lane_cliente">
          <mxGeometry x="120" y="380" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_client_exit" value="Encerrar Programa" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_cliente">
          <mxGeometry x="20" y="470" width="110" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_end_fail" value="End" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_cliente">
          <mxGeometry x="60" y="540" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- LOOP MENU -->
        <mxCell id="act_srv_menu" value="Apresentar MENU de operações" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="40" y="470" width="160" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_client_menu" value="Apresentar menu e enviar opção" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="170" y="470" width="160" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_srv_cmd" value="Qual Comando?" style="rhombus;" vertex="1" parent="lane_servidor">
          <mxGeometry x="130" y="550" width="110" height="60" as="geometry" />
        </mxCell>

        <!-- CMD: SAIR -->
        <mxCell id="act_srv_exit" value="Encerrar conexão com cliente" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_servidor">
          <mxGeometry x="240" y="630" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- CMD: SALDO -->
        <mxCell id="act_srv_saldo" value="Retornar SALDO ATUAL" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="10" y="630" width="110" height="40" as="geometry" />
