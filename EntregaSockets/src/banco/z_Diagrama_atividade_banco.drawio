        </mxCell>

        <mxCell id="act_saque_fail" value="Retornar ERRO: Saldo insuficiente" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_servidor">
          <mxGeometry x="200" y="850" width="130" height="40" as="geometry" />
        </mxCell>

        <!-- CLIENT END SUCCESS -->
        <mxCell id="act_client_end" value="End" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_cliente">
          <mxGeometry x="235" y="800" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- EDGES WITH PARENT='1' AND MXGEOMETRY -->
        <mxCell id="edge1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_start" target="act_connect">
