<mxfile host="app.diagrams.net" pages="1">
  <diagram id="banco_sequence" name="Sequence Diagram">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="sd BankTransactions" style="shape=umlFrame;whiteSpace=wrap;html=1;width=140;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="850" height="740" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lifeline_cliente" value=":Cliente" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="120" y="80" width="100" height="620" as="geometry" />
        </mxCell>
        <mxCell id="act_cliente" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="520" as="geometry" />
        </mxCell>

        <mxCell id="lifeline_servidor" value=":Servidor" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="420" y="80" width="100" height="620" as="geometry" />
        </mxCell>
        <mxCell id="act_servidor" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="520" as="geometry" />
        </mxCell>

        <mxCell id="lifeline_contas" value=":Contas (Map)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="720" y="80" width="100" height="620" as="geometry" />
        </mxCell>
        <mxCell id="act_contas" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lifeline_contas" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="520" as="geometry" />
        </mxCell>

        <!-- Welcome flow messages -->
        <mxCell id="msg_connect" value="1: Conectar" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="160" as="sourcePoint" />
            <mxPoint x="460" y="160" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_welcome" value="1.1: BEM-VINDO. DIGITE O NUMERO DA CONTA:" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="180" as="sourcePoint" />
            <mxPoint x="180" y="180" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_send_acc" value="1.2: Envia conta" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="210" as="sourcePoint" />
            <mxPoint x="460" y="210" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="210" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_check_acc" value="1.3: containsKey(conta)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_contas">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="230" as="sourcePoint" />
            <mxPoint x="760" y="230" as="targetPoint" />
            <Array as="points">
              <mxPoint x="620" y="230" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg_check_acc_res" value="1.4: Retorna booleano" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_contas" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="760" y="250" as="sourcePoint" />
            <mxPoint x="480" y="250" as="targetPoint" />
            <Array as="points">
              <mxPoint x="620" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Loop Frame for Menu operations -->
        <mxCell id="loop_frame" value="loop" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="50" y="270" width="810" height="460" as="geometry" />
        </mxCell>
        
        <mxCell id="txt_loop_cond" value="[enquanto conta existir e cmd != 4]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="50" y="285" width="200" height="20" as="geometry" />
        </mxCell>

        <mxCell id="msg_menu" value="2: Apresentar MENU e ler comando" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="320" as="sourcePoint" />
            <mxPoint x="180" y="320" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg_cmd" value="2.1: Envia cmd (1, 2 ou 3)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_cliente" target="act_servidor">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="350" as="sourcePoint" />
            <mxPoint x="460" y="350" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="350" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Operation Alt Frame inside Loop -->
        <mxCell id="op_alt" value="alt" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="70" y="380" width="770" height="330" as="geometry" />
        </mxCell>

        <!-- Case 1: SALDO -->
        <mxCell id="txt_cond_saldo" value="[cmd == 1 (SALDO)]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="70" y="390" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="msg_get_balance" value="3: get(conta)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_contas">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="420" as="sourcePoint" />
            <mxPoint x="760" y="420" as="targetPoint" />
            <Array as="points">
              <mxPoint x="620" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg_get_balance_res" value="3.1: SALDO ATUAL: &lt;valor&gt;" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="450" as="sourcePoint" />
            <mxPoint x="180" y="450" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- First Alt Divider -->
        <mxCell id="alt_div1" value="" style="endArrow=none;dashed=1;html=1;rounded=0;exitX=0;exitY=0.33;exitDx=0;exitDy=0;exitPerimeter=0;entryX=1;entryY=0.33;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="op_alt" target="op_alt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Case 2: DEPOSITO -->
        <mxCell id="txt_cond_dep" value="[cmd == 2 (DEPOSITO)]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="70" y="495" width="140" height="20" as="geometry" />
        </mxCell>

        <mxCell id="msg_put_dep" value="4: put(conta, saldo + valor)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_contas">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="525" as="sourcePoint" />
