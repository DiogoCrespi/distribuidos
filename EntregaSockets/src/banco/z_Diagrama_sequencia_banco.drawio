        <mxCell id="msg_dep_res" value="4.1: SUCESSO: Deposito realizado" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="555" as="sourcePoint" />
            <mxPoint x="180" y="555" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="555" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Second Alt Divider -->
        <mxCell id="alt_div2" value="" style="endArrow=none;dashed=1;html=1;rounded=0;exitX=0;exitY=0.66;exitDx=0;exitDy=0;exitPerimeter=0;entryX=1;entryY=0.66;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="op_alt" target="op_alt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Case 3: SAQUE -->
        <mxCell id="txt_cond_saque" value="[cmd == 3 (SAQUE)]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="70" y="605" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="msg_put_saque" value="5: put(conta, saldo - valor) [se saldo >= valor]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_contas">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="635" as="sourcePoint" />
            <mxPoint x="760" y="635" as="targetPoint" />
            <Array as="points">
              <mxPoint x="620" y="635" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg_saque_res" value="5.1: SUCESSO: Saque realizado / ERRO" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="act_servidor" target="act_cliente">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="665" as="sourcePoint" />
            <mxPoint x="180" y="665" as="targetPoint" />
            <Array as="points">
