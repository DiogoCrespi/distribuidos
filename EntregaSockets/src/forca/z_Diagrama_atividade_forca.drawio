        </mxCell>

        <mxCell id="act_send_state" value="Enviar ESTADO e erros" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="390" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_recv_guess" value="Receber palpite" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="460" width="150" height="40" as="geometry" />
