        <mxCell id="act_send_victory" value="Enviar VITORIA" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="20" y="860" width="140" height="40" as="geometry" />
