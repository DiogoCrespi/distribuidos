<mxfile host="app.diagrams.net" pages="1">
  <diagram id="forca_activity" name="Activity Diagram">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Swimlanes for Client and Server -->
        <mxCell id="swimlanes" value="Jogo da Forca" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="760" height="1060" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_cliente" value="Cliente (ClienteForca.java)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="370" height="1040" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_servidor" value="Servidor/Thread (ServidorForca.java)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="390" y="20" width="370" height="1040" as="geometry" />
        </mxCell>

        <!-- CLIENT FLOW -->
        <mxCell id="act_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_cliente">
          <mxGeometry x="170" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="act_connect" value="Conectar ao Servidor (localhost:12347)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="100" y="90" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_read_welcome" value="Ler boas-vindas e TAMANHO" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="160" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_read_loop" value="Ler mensagem do Socket" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="230" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_msg_type" value="Qual tipo?" style="rhombus;" vertex="1" parent="lane_cliente">
          <mxGeometry x="135" y="300" width="100" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_print_state" value="Exibir estado e ler letra do console" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="90" y="400" width="190" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_send_letter" value="Enviar palpite pelo socket" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="470" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_print_msg" value="Exibir mensagem de aviso" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="540" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_print_result" value="Exibir Vitória ou Derrota" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="620" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_client_exit" value="Encerrar Programa" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_cliente">
          <mxGeometry x="125" y="690" width="120" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_end" value="End" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_cliente">
          <mxGeometry x="170" y="760" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- SERVER FLOW -->
        <mxCell id="act_server_init" value="Aguardar conexão (accept)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="100" y="30" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_accept_conn" value="Aceitar e iniciar ThreadJogo" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="100" y="90" width="170" height="40" as="geometry" />
