        <mxCell id="act_game_init" value="Sortear palavra e iniciar estado" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="90" y="160" width="190" height="40" as="geometry" />
