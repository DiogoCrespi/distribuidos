        <mxCell id="act_send_defeat" value="Enviar DERROTA" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_servidor">
          <mxGeometry x="210" y="860" width="140" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_close_socket" value="Fechar socket de jogo" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="950" width="150" height="40" as="geometry" />
