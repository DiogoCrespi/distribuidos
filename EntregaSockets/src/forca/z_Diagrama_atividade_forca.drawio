        <mxCell id="act_send_welcome" value="Enviar Boas-vindas e TAMANHO" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="100" y="230" width="170" height="40" as="geometry" />
