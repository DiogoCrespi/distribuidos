<mxfile host="app.diagrams.net" pages="1">
  <diagram id="lojas_collaboration" name="Collaboration Diagram">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="co Simulação de Lojas via Sockets (Diagrama de Colaboração)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=410;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="840" height="520" as="geometry" />
        </mxCell>

        <!-- Objects (Nodes) -->
        
        <!-- filial : FilialSimulador (Active Object) -->
        <mxCell id="obj_filial" value="&lt;u&gt;filial : FilialSimulador&lt;/u&gt;" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="240" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- central : SistemaCentral (Active Object) -->
        <mxCell id="obj_central" value="&lt;u&gt;central : SistemaCentral&lt;/u&gt;" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="100" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- thread : ThreadFilial (Active Object) -->
        <mxCell id="obj_thread" value="&lt;u&gt;thread : ThreadFilial&lt;/u&gt;" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="380" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Legend Box -->
        <mxCell id="note_legend" value="&lt;b&gt;Legenda de Cores e Estereótipos:&lt;/b&gt;&lt;br&gt;- &lt;font color=&quot;#d79b00&quot;&gt;&lt;b&gt;Laranja:&lt;/b&gt;&lt;/font&gt; Classe Ativa FilialSimulador (Simulação de Vendas)&lt;br&gt;- &lt;font color=&quot;#6c8ebf&quot;&gt;&lt;b&gt;Azul:&lt;/b&gt;&lt;/font&gt; Classe Ativa SistemaCentral (Servidor Principal)&lt;br&gt;- &lt;font color=&quot;#82b366&quot;&gt;&lt;b&gt;Verde:&lt;/b&gt;&lt;/font&gt; Classe Ativa ThreadFilial (Tratador de Conexões)&lt;br&gt;- &lt;b&gt;Setas Sólidas:&lt;/b&gt; Envio de dados, conexões e chamadas síncronas&lt;br&gt;- &lt;b&gt;Self-Loops:&lt;/b&gt; Operações internas / processamento local." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="320" height="120" as="geometry" />
        </mxCell>

        <!-- Concurrency Notes Box -->
        <mxCell id="note_concurrency" value="&lt;b&gt;Notas de Concorrência &amp; Sockets:&lt;/b&gt;&lt;br&gt;- &lt;b&gt;Sistema Multithread:&lt;/b&gt; O servidor central aguarda novas conexões em loop síncrono. Ao receber uma conexão (`accept`), spawna uma nova `ThreadFilial` de execução independente.&lt;br&gt;- &lt;b&gt;Envio Contínuo (Simulado):&lt;/b&gt; Cada filial executa 1500 transações de venda com intervalos de 10ms via Socket.&lt;br&gt;- &lt;b&gt;Sincronização:&lt;/b&gt; O método `adicionarVenda(valor)` é `synchronized` para evitar race conditions na atualização concorrente do saldo consolidado `totalVendas`." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="320" height="150" as="geometry" />
        </mxCell>

        <!-- Edges (Links with Messages) -->

        <!-- Link 1: filial to central (Socket connection) -->
        <mxCell id="edge_filial_central" edge="1" parent="1" source="obj_filial" target="obj_central" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;fillColor=#ffe6cc;exitX=1;exitY=0.25;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_filial_central" connectable="0" parent="edge_filial_central" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="1: Conectar Socket (new Socket) ↗" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-10" y="-18" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 1.2: central to thread (spawn thread) -->
        <mxCell id="edge_central_thread" edge="1" parent="1" source="obj_central" target="obj_thread" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#6c8ebf;fillColor=#dae8fc;exitX=0.25;exitY=1;entryX=0.25;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_central_thread" connectable="0" parent="edge_central_thread" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="1.2: new ThreadFilial(socket).start() ⬇" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-100" y="0" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 2.3: thread to central (adicionarVenda) -->
        <mxCell id="edge_thread_central" edge="1" parent="1" source="obj_thread" target="obj_central" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#82b366;fillColor=#d5e8d4;exitX=0.75;exitY=0;entryX=0.75;entryY=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_thread_central" connectable="0" parent="edge_thread_central" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="2.3: adicionarVenda(valor) [synchronized] ↖" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="110" y="0" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 2, 2.2, 3: filial to thread (socket communication) -->
        <mxCell id="edge_filial_thread" edge="1" parent="1" source="obj_filial" target="obj_thread" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;fillColor=#ffe6cc;exitX=1;exitY=0.75;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_filial_thread" connectable="0" parent="edge_filial_thread" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="2: Enviar filialId ↘&lt;br&gt;2.2: Enviar valor da venda ↘&lt;br&gt;3: Fechar Socket (fim da simulação) ↘" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-5" y="32" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Self-loop: filial (generate sales values) -->
        <mxCell id="edge_filial_self" edge="1" parent="1" source="obj_filial" target="obj_filial" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fontSize=12;strokeColor=#d79b00;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="160" y="190" />
              <mxPoint x="240" y="190" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_filial_self" connectable="0" parent="edge_filial_self" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="2.1: valor = rand(10, 500) ↻" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Self-loop: central (accept connection) -->
        <mxCell id="edge_central_self" edge="1" parent="1" source="obj_central" target="obj_central" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fontSize=12;strokeColor=#6c8ebf;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="50" />
              <mxPoint x="640" y="50" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_central_self" connectable="0" parent="edge_central_self" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="1.1: accept() conexão ↻" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Self-loop: thread (print consolidated totals) -->
        <mxCell id="edge_thread_self" edge="1" parent="1" source="obj_thread" target="obj_thread" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=1;entryDx=0;entryDy=0;fontSize=12;strokeColor=#82b366;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="470" />
              <mxPoint x="640" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_thread_self" connectable="0" parent="edge_thread_self" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="3.1: Exibir total acumulado ↻" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="15" as="offset" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
