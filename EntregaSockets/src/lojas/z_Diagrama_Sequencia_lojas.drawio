<mxfile host="app.diagrams.net" pages="1">
  <diagram id="lojas_sequence" name="Sequence Diagram">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="sd Simulacao de Lojas" style="shape=umlFrame;whiteSpace=wrap;html=1;width=200;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="810" height="660" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        
        <!-- Lifeline 1: Cliente Filial -->
        <mxCell id="lifeline_cliente" value=":Filial" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="100" y="80" width="100" height="560" as="geometry" />
        </mxCell>
        <mxCell id="act_filial" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="450" as="geometry" />
        </mxCell>
        <mxCell id="act_filial_rand" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="50" y="210" width="10" height="30" as="geometry" />
        </mxCell>

        <!-- Lifeline 2: Sistema Central -->
        <mxCell id="lifeline_servidor" value=":SistemaCentral" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="350" y="80" width="120" height="560" as="geometry" />
        </mxCell>
        <mxCell id="act_central" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="55" y="70" width="10" height="450" as="geometry" />
        </mxCell>
        <mxCell id="act_central_accept" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="60" y="100" width="10" height="20" as="geometry" />
        </mxCell>
        <mxCell id="act_central_add" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_servidor" vertex="1">
          <mxGeometry x="60" y="290" width="10" height="30" as="geometry" />
        </mxCell>

        <!-- Lifeline 3: ThreadFilial -->
        <mxCell id="lifeline_thread" value=":ThreadFilial" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="600" y="80" width="120" height="560" as="geometry" />
        </mxCell>
        <mxCell id="act_thread" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lifeline_thread" vertex="1">
          <mxGeometry x="55" y="120" width="10" height="400" as="geometry" />
        </mxCell>
        <mxCell id="act_thread_print" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lifeline_thread" vertex="1">
          <mxGeometry x="60" y="440" width="10" height="30" as="geometry" />
        </mxCell>

        <!-- Loop Frame for Branch Transactions -->
        <mxCell id="loop_frame" value="loop" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="40" y="260" width="760" height="190" as="geometry" />
        </mxCell>
        
        <mxCell id="txt_loop_cond" value="[loop 1500 vezes (i = 1 até 1500)]" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="40" y="275" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- Messages -->
        
        <!-- 1: Client Connect -->
        <mxCell id="msg_connect" value="1: Conectar Socket (new Socket)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_filial" target="act_central">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="155" y="150" as="sourcePoint" />
            <mxPoint x="405" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 1.1: Server Accept -->
        <mxCell id="msg_accept" value="1.1: accept() conexão" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_central" target="act_central_accept">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="430" y="170" />
              <mxPoint x="430" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 1.2: Spawn Thread -->
        <mxCell id="msg_spawn" value="1.2: new ThreadFilial(socket).start()" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_central" target="act_thread">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="415" y="200" as="sourcePoint" />
            <mxPoint x="645" y="200" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 2: Send filialId -->
        <mxCell id="msg_send_id" value="2: Enviar filialId" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_filial" target="act_thread">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="155" y="230" as="sourcePoint" />
            <mxPoint x="645" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Inside loop -->
        <!-- 2.1: Generate value -->
        <mxCell id="msg_rand" value="2.1: valor = rand(10, 500)" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_filial" target="act_filial_rand">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="170" y="295" />
              <mxPoint x="170" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 2.2: Send value -->
        <mxCell id="msg_send_val" value="2.2: Enviar valor da venda" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_filial" target="act_thread">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="155" y="350" as="sourcePoint" />
            <mxPoint x="645" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 2.3: Call adicionarVenda() -->
        <mxCell id="msg_add_val" value="2.3: adicionarVenda(valor) [synchronized]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_thread" target="act_central_add">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="645" y="370" as="sourcePoint" />
            <mxPoint x="415" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Outside loop -->
        <!-- 3: Close connection -->
        <mxCell id="msg_close" value="3: Fechar Socket (fim da simulação)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_filial" target="act_thread">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="155" y="490" as="sourcePoint" />
            <mxPoint x="645" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 3.1: Print totals in console -->
        <mxCell id="msg_print_totals" value="3.1: Exibir total acumulado" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_thread" target="act_thread_print">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="525" />
              <mxPoint x="680" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>