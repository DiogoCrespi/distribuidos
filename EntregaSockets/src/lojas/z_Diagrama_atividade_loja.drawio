<mxfile host="app.diagrams.net" pages="1">
  <diagram id="lojas_activity" name="Activity Diagram">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Swimlanes for Client and Server -->
        <mxCell id="swimlanes" value="Simulação de Lojas Concorrente" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="760" height="1060" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_cliente" value="Filial (FilialSimulador.java)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="370" height="1040" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_servidor" value="Sistema Central (SistemaCentral.java)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="390" y="20" width="370" height="1040" as="geometry" />
        </mxCell>

        <!-- CLIENT FLOW -->
        <mxCell id="act_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_cliente">
          <mxGeometry x="170" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="act_get_id" value="Obter filialId (args[0] ou rand)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="95" y="90" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_open_socket" value="Abrir Socket (porta 12349)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="95" y="160" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_send_id" value="Enviar filialId ao Servidor" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="110" y="230" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_init_loop" value="i = 1" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="135" y="300" width="100" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_loop_cond" value="i &lt;= 1500?" style="rhombus;" vertex="1" parent="lane_cliente">
          <mxGeometry x="125" y="370" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_gen_sale" value="Gerar venda aleatória (10 a 500)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="95" y="470" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_send_sale" value="Enviar valor pelo socket" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="105" y="540" width="160" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_delay" value="Aguardar delay (sleep 10ms)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="105" y="610" width="160" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_inc_i" value="i = i + 1" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
          <mxGeometry x="135" y="680" width="100" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_close_socket" value="Fechar Socket da filial" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_cliente">
          <mxGeometry x="120" y="760" width="130" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_end_client" value="End" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_cliente">
          <mxGeometry x="170" y="830" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- SERVER FLOW -->
        <mxCell id="act_srv_accept" value="Aguardar conexão (accept)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="100" y="90" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_spawn_thread" value="Criar e iniciar ThreadFilial" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="90" y="160" width="190" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_thread_start" value="Thread iniciada concorrentemente" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="85" y="230" width="200" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_read_id" value="Ler filialId" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="120" y="300" width="130" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_read_line" value="Ler linha do socket" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="370" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_srv_eof" value="registro == null (EOF)?" style="rhombus;" vertex="1" parent="lane_servidor">
          <mxGeometry x="100" y="440" width="170" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_parse_sale" value="Parse valor para double" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="530" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_add_sale" value="adicionarVenda(valor)&#xa;[synchronized]" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_servidor">
          <mxGeometry x="95" y="600" width="180" height="45" as="geometry" />
        </mxCell>

        <mxCell id="act_inc_count" value="Incrementar contador local" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="105" y="670" width="160" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_print_summary" value="Exibir logs de fechamento&#xa;e total geral acumulado" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_servidor">
          <mxGeometry x="85" y="750" width="200" height="45" as="geometry" />
        </mxCell>

        <mxCell id="act_thread_end" value="Encerrar Thread da filial" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_servidor">
          <mxGeometry x="110" y="820" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- EDGES WITH parent="1" -->

        <!-- Client Flow -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_start" target="act_get_id">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_get_id" target="act_open_socket">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_open_socket" target="act_send_id">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_send_id" target="act_init_loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_init_loop" target="dec_loop_cond">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_loop_cond" target="act_gen_sale" value="Sim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_gen_sale" target="act_send_sale">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_send_sale" target="act_delay">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_delay" target="act_inc_i">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="act_inc_i" target="dec_loop_cond">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="700" />
              <mxPoint x="80" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_loop_cond" target="act_close_socket" value="Não">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="400" />
              <mxPoint x="320" y="740" />
              <mxPoint x="185" y="740" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_close_socket" target="act_end_client">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Server Loop Flow -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_srv_accept" target="act_spawn_thread">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="act_spawn_thread" target="act_srv_accept">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="310" y="180" />
              <mxPoint x="310" y="110" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ThreadFilial Flow -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_thread_start" target="act_read_id">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_read_id" target="act_read_line">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_read_line" target="dec_srv_eof">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_srv_eof" target="act_parse_sale" value="Não">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_parse_sale" target="act_add_sale">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_add_sale" target="act_inc_count">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e21" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="act_inc_count" target="act_read_line">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="310" y="690" />
              <mxPoint x="310" y="390" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e22" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_srv_eof" target="act_print_summary" value="Sim">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="50" y="470" />
              <mxPoint x="50" y="730" />
              <mxPoint x="185" y="730" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_print_summary" target="act_thread_end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Concurrency invocation link -->
        <mxCell id="e_thread_start" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_spawn_thread" target="act_thread_start">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- NETWORK MESSAGES -->
        
        <!-- Socket connection -->
        <mxCell id="e_net_conn" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_open_socket" target="act_srv_accept">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="310" y="180" />
              <mxPoint x="310" y="110" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Send filialId -->
        <mxCell id="e_net_id" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_send_id" target="act_read_id">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="250" />
              <mxPoint x="330" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Send transaction value -->
        <mxCell id="e_net_sale" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_send_sale" target="act_read_line">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="560" />
              <mxPoint x="330" y="390" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- EOF signal -->
        <mxCell id="e_net_eof" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_close_socket" target="dec_srv_eof">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="780" />
              <mxPoint x="330" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
