<mxfile host="app.diagrams.net" pages="1">
  <diagram id="chat_activity" name="Activity Diagram">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Swimlanes for Main Thread and Reader Thread -->
        <mxCell id="swimlanes" value="Chat Multicast (ChatMulticast.java)" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="760" height="960" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_main" value="Thread Principal (Envio / Console)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="370" height="940" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_receptora" value="Thread Receptora (Background Reader)" style="swimlane;startSize=20;html=1;" parent="swimlanes" vertex="1">
          <mxGeometry x="390" y="20" width="370" height="940" as="geometry" />
        </mxCell>

        <!-- MAIN THREAD FLOW -->
        <mxCell id="act_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_main">
          <mxGeometry x="170" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="act_init" value="Solicitar apelido e criar MulticastSocket (12351)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_main">
          <mxGeometry x="85" y="90" width="200" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_join" value="joinGroup(224.0.0.1)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_main">
          <mxGeometry x="110" y="160" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- Fork node to spawn Reader thread -->
        <mxCell id="fork_thread" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_main">
          <mxGeometry x="85" y="230" width="200" height="6" as="geometry" />
        </mxCell>

        <!-- Main Thread Loop -->
        <mxCell id="act_read_console" value="Aguardar e ler mensagem do console" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_main">
          <mxGeometry x="100" y="270" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_msg" value="Mensagem == 'SAIR'?" style="rhombus;" vertex="1" parent="lane_main">
          <mxGeometry x="120" y="340" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_send_pkt" value="Enviar DatagramPacket formatado para o canal" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_main">
          <mxGeometry x="90" y="430" width="190" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_leave_group" value="leaveGroup(224.0.0.1) e fechar socket" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_main">
          <mxGeometry x="90" y="520" width="190" height="40" as="geometry" />
        </mxCell>

        <!-- Join node to merge paths before end -->
        <mxCell id="join_thread" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_main">
          <mxGeometry x="85" y="600" width="200" height="6" as="geometry" />
        </mxCell>

        <mxCell id="act_end" value="End" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_main">
          <mxGeometry x="170" y="640" width="30" height="30" as="geometry" />
        </mxCell>


        <!-- READER THREAD FLOW -->
        <mxCell id="act_read_loop" value="Loop: socket.receive(pacote)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_receptora">
          <mxGeometry x="100" y="270" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_filter" value="Mensagem de si mesmo?" style="rhombus;" vertex="1" parent="lane_receptora">
          <mxGeometry x="110" y="340" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="act_print_msg" value="Imprimir mensagem no terminal" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_receptora">
          <mxGeometry x="100" y="430" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_catch_closed" value="IOException: Conexão fechada" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_receptora">
          <mxGeometry x="100" y="520" width="170" height="40" as="geometry" />
        </mxCell>


        <!-- EDGES WITH PARENT='1' AND MXGEOMETRY -->
        <mxCell id="edge1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_start" target="act_init">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_init" target="act_join">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_join" target="fork_thread">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Fork edges -->
        <mxCell id="edge_fork_main" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="fork_thread" target="act_read_console">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_fork_reader" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="fork_thread" target="act_read_loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Main Loop edges -->
        <mxCell id="edge5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_read_console" target="dec_msg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_msg" target="act_send_pkt" value="não">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;" edge="1" parent="1" source="act_send_pkt" target="act_read_console">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="70" y="470" />
              <mxPoint x="70" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="edge8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_msg" target="act_leave_group" value="sim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_leave_group" target="join_thread">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Reader Loop edges -->
        <mxCell id="edge10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_read_loop" target="dec_filter">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="dec_filter" target="act_read_loop" value="sim">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="390" />
              <mxPoint x="750" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="edge12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_filter" target="act_print_msg" value="não">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="act_print_msg" target="act_read_loop">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="470" />
              <mxPoint x="750" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Exception Edge when socket is closed -->
        <mxCell id="edge14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="act_read_loop" target="act_catch_closed" value="IOException (socket fechado)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_catch_closed" target="join_thread">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Join to End -->
        <mxCell id="edge16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="join_thread" target="act_end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>