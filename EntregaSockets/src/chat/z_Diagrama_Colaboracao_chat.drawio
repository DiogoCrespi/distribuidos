<mxfile host="app.diagrams.net" pages="1">
  <diagram id="chat_collaboration" name="Collaboration Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="co Chat Multicast via UDP (Diagrama de Colaboração)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=410;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1000" height="650" as="geometry" />
        </mxCell>

        <!-- Objects (Nodes) -->
        
        <!-- clientA : Cliente (Active Object - local process Maria) -->
        <mxCell id="obj_clientA" value="&lt;u&gt;clientA : Cliente&lt;/u&gt;&lt;br&gt;(Maria)" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="250" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- canal : Multicast (Passive Object - UDP Network group) -->
        <mxCell id="obj_canal" value="&lt;u&gt;canal : Multicast&lt;/u&gt;&lt;br&gt;(224.0.0.1)" style="whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="250" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- clientB : Cliente (Active Object - local process João) -->
        <mxCell id="obj_clientB" value="&lt;u&gt;clientB : Cliente&lt;/u&gt;&lt;br&gt;(João)" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="250" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Note Box: Concurrency & Multicast notes -->
        <mxCell id="note_concurrency" value="&lt;b&gt;Comunicação Multicast via UDP:&lt;/b&gt;&lt;br&gt;- &lt;b&gt;clientA e clientB:&lt;/b&gt; Processos clientes ativos (threads independentes de envio e recepção) rodando no console.&lt;br&gt;- &lt;b&gt;canal (224.0.0.1):&lt;/b&gt; Grupo Multicast UDP. O roteador/switch envia as mensagens para todas as interfaces de rede inscritas no grupo.&lt;br&gt;- &lt;b&gt;Filtragem de Remetente:&lt;/b&gt; As mensagens recebidas por &lt;i&gt;receive()&lt;/i&gt; que iniciam com o próprio apelido são ignoradas localmente (evitando ecoar a própria mensagem).&lt;br&gt;- &lt;b&gt;Assincronismo:&lt;/b&gt; O recebimento de mensagens é assíncrono (executado em thread de background) permitindo o envio simultâneo de novas mensagens no loop da thread principal." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="450" height="180" as="geometry" />
        </mxCell>

        <!-- Legend Box -->
        <mxCell id="note_legend" value="&lt;b&gt;Legenda de Cores e Estereótipos:&lt;/b&gt;&lt;br&gt;- &lt;font color=&quot;#d79b00&quot;&gt;&lt;b&gt;Laranja:&lt;/b&gt;&lt;/font&gt; Classe Ativa Cliente A (Processo Maria)&lt;br&gt;- &lt;font color=&quot;#82b366&quot;&gt;&lt;b&gt;Verde:&lt;/b&gt;&lt;/font&gt; Classe Ativa Cliente B (Processo João)&lt;br&gt;- &lt;font color=&quot;#6c8ebf&quot;&gt;&lt;b&gt;Azul:&lt;/b&gt;&lt;/font&gt; Canal de Multicast (Rede UDP Grupo)&lt;br&gt;- &lt;b&gt;Setas Sólidas (➔):&lt;/b&gt; Envio de Datagramas / Inscrição no Grupo&lt;br&gt;- &lt;b&gt;Self-Loops (↻):&lt;/b&gt; Operações locais (exibição, encerramento de sockets)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="420" width="370" height="180" as="geometry" />
        </mxCell>

        <!-- Edges (Links with Messages) -->

        <!-- self-call: clientA (exibir, close) -->
        <mxCell id="edge_clientA_self" edge="1" parent="1" source="obj_clientA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fontSize=12;strokeColor=#d79b00;strokeWidth=1.5;" target="obj_clientA">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="200" />
              <mxPoint x="240" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_clientA_self" connectable="0" parent="edge_clientA_self" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="4.2: Exibe 'Joao: Oi Maria!'&lt;br&gt;5.1: socket.close()" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-20" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 1: clientA to canal (join, send calls) -->
        <mxCell id="edge_clientA_canal" edge="1" parent="1" source="obj_clientA" target="obj_canal" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#d79b00;fillColor=#ffe6cc;exitX=1;exitY=0.3;entryX=0;entryY=0.3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_clientA_canal" connectable="0" parent="edge_clientA_canal" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="1: joinGroup(224.0.0.1)&lt;br&gt;3: send(DatagramPacket('Maria: Ola!'))&lt;br&gt;5: leaveGroup(224.0.0.1)" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-22" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 1 Return: canal to clientA (receives) -->
        <mxCell id="edge_canal_clientA" edge="1" parent="1" source="obj_canal" target="obj_clientA" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#d79b00;fillColor=#ffe6cc;exitX=0;exitY=0.7;entryX=1;entryY=0.7;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_canal_clientA" connectable="0" parent="edge_canal_clientA" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="3.3: receive(DatagramPacket) [ignorado]&lt;br&gt;4.1: receive(DatagramPacket) [repassa]" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="22" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- self-call: clientB (exibir) -->
        <mxCell id="edge_clientB_self" edge="1" parent="1" source="obj_clientB" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fontSize=12;strokeColor=#82b366;strokeWidth=1.5;" target="obj_clientB">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="840" y="200" />
              <mxPoint x="900" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_clientB_self" connectable="0" parent="edge_clientB_self" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="3.2: Exibe 'Maria: Ola!'" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 2: clientB to canal (join, send calls) -->
        <mxCell id="edge_clientB_canal" edge="1" parent="1" source="obj_clientB" target="obj_canal" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#82b366;fillColor=#d5e8d4;exitX=0;exitY=0.3;entryX=1;entryY=0.3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_clientB_canal" connectable="0" parent="edge_clientB_canal" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="2: joinGroup(224.0.0.1)&lt;br&gt;4: send(DatagramPacket('Joao: Oi Maria!'))" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-22" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 2 Return: canal to clientB (receives) -->
        <mxCell id="edge_canal_clientB" edge="1" parent="1" source="obj_canal" target="obj_clientB" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#82b366;fillColor=#d5e8d4;exitX=1;exitY=0.7;entryX=0;entryY=0.7;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_canal_clientB" connectable="0" parent="edge_canal_clientB" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="3.1: receive(DatagramPacket) [repassa]" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="15" as="offset" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
