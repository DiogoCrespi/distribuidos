<mxfile host="app.diagrams.net" pages="1">
  <diagram id="chat_sequence" name="Sequence Diagram">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1019" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="sd MulticastChat" style="shape=umlFrame;whiteSpace=wrap;html=1;width=140;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="850" height="740" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lifeline_client_a" value=":Cliente_A (Maria)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="100" y="80" width="120" height="620" as="geometry" />
        </mxCell>
        <mxCell id="act_client_a" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_client_a" vertex="1">
          <mxGeometry x="55" y="70" width="10" height="520" as="geometry" />
        </mxCell>

        <mxCell id="lifeline_group" value="Canal Multicast (224.0.0.1)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="380" y="80" width="180" height="620" as="geometry" />
        </mxCell>
        <mxCell id="act_group" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lifeline_group" vertex="1">
          <mxGeometry x="85" y="70" width="10" height="520" as="geometry" />
        </mxCell>

        <mxCell id="lifeline_client_b" value=":Cliente_B (João)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="680" y="80" width="120" height="620" as="geometry" />
        </mxCell>
        <mxCell id="act_client_b" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lifeline_client_b" vertex="1">
          <mxGeometry x="55" y="70" width="10" height="520" as="geometry" />
        </mxCell>

        <!-- Maria joins group -->
        <mxCell id="msg_join_a" value="1: joinGroup(224.0.0.1)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_client_a" target="act_group">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="160" as="sourcePoint" />
            <mxPoint x="460" y="160" as="targetPoint" />
            <Array as="points">
              <mxPoint x="310" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Joao joins group -->
        <mxCell id="msg_join_b" value="2: joinGroup(224.0.0.1)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_client_b" target="act_group">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="180" as="sourcePoint" />
            <mxPoint x="480" y="180" as="targetPoint" />
            <Array as="points">
              <mxPoint x="610" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Maria sends message -->
        <mxCell id="msg_send_a" value="3: send(DatagramPacket('Maria: Ola!'))" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_client_a" target="act_group">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="240" as="sourcePoint" />
            <mxPoint x="460" y="240" as="targetPoint" />
            <Array as="points">
              <mxPoint x="310" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Multicast Broadcasts to Joao -->
        <mxCell id="msg_cast_joao" value="3.1: receive(DatagramPacket) [repassa para todos]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_group" target="act_client_b">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="270" as="sourcePoint" />
            <mxPoint x="730" y="270" as="targetPoint" />
            <Array as="points">
              <mxPoint x="610" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Joao prints message -->
        <mxCell id="act_b_print" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lifeline_client_b" vertex="1">
          <mxGeometry x="60" y="200" width="10" height="30" as="geometry" />
        </mxCell>
        <mxCell id="msg_b_print" value="3.2: Exibe 'Maria: Ola!' (nao e remetente)" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;entryX=1;entryY=0;" edge="1" parent="lifeline_client_b" source="act_client_b" target="act_b_print">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="90" y="190" />
              <mxPoint x="90" y="200" />
            </Array>
            <mxPoint x="65" y="190" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

        <!-- Multicast Broadcasts to Maria (ignored) -->
        <mxCell id="msg_cast_maria" value="3.3: receive(DatagramPacket) [ignorado por ser remetente]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_group" target="act_client_a">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="320" as="sourcePoint" />
            <mxPoint x="160" y="320" as="targetPoint" />
            <Array as="points">
              <mxPoint x="310" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Joao sends message -->
        <mxCell id="msg_send_b" value="4: send(DatagramPacket('Joao: Oi Maria!'))" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_client_b" target="act_group">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="390" as="sourcePoint" />
            <mxPoint x="480" y="390" as="targetPoint" />
            <Array as="points">
              <mxPoint x="610" y="390" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Multicast Broadcasts to Maria -->
        <mxCell id="msg_cast_maria2" value="4.1: receive(DatagramPacket) [repassa para todos]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_group" target="act_client_a">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="420" as="sourcePoint" />
            <mxPoint x="160" y="420" as="targetPoint" />
            <Array as="points">
              <mxPoint x="310" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Maria prints message -->
        <mxCell id="act_a_print" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_client_a" vertex="1">
          <mxGeometry x="60" y="350" width="10" height="30" as="geometry" />
        </mxCell>
        <mxCell id="msg_a_print" value="4.2: Exibe 'Joao: Oi Maria!'" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;entryX=1;entryY=0;" edge="1" parent="lifeline_client_a" source="act_client_a" target="act_a_print">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="90" y="340" />
              <mxPoint x="90" y="350" />
            </Array>
            <mxPoint x="65" y="340" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

        <!-- Maria leaves chat -->
        <mxCell id="msg_leave_a" value="5: leaveGroup(224.0.0.1) [SAIR]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="act_client_a" target="act_group">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="500" as="sourcePoint" />
            <mxPoint x="460" y="500" as="targetPoint" />
            <Array as="points">
              <mxPoint x="310" y="500" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Maria closes socket -->
        <mxCell id="act_a_close" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_client_a" vertex="1">
          <mxGeometry x="60" y="450" width="10" height="30" as="geometry" />
        </mxCell>
        <mxCell id="msg_a_close" value="5.1: socket.close()" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;entryX=1;entryY=0;" edge="1" parent="lifeline_client_a" source="act_client_a" target="act_a_close">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="90" y="440" />
              <mxPoint x="90" y="450" />
            </Array>
            <mxPoint x="65" y="440" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>