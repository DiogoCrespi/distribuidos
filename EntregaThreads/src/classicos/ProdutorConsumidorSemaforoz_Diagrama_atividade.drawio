        <mxCell id="ec4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="cons_acq_mutex" target="res_mutex_dec_cons">
          <mxGeometry relative="1" as="geometry" />
