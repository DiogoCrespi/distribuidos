        <mxCell id="ep3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="prod_acq_vazio" target="res_vazio_dec">
          <mxGeometry relative="1" as="geometry" />
