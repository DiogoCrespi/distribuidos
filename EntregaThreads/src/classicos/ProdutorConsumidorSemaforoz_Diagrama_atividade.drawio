        <mxCell id="ep6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_mutex_dec_prod" target="prod_insert">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="prod_insert" target="res_buffer_add">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_buffer_add" target="prod_rel_mutex">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="prod_rel_mutex" target="res_mutex_inc_prod">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_mutex_inc_prod" target="prod_rel_cheio">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="prod_rel_cheio" target="res_cheio_inc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_cheio_inc" target="prod_sleep">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="prod_sleep" target="prod_item">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="600" />
              <mxPoint x="80" y="130" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Consumidor Transitions -->
        <mxCell id="ec1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="cons_start" target="cons_acq_cheio">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="cons_acq_cheio" target="res_cheio_dec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_cheio_dec" target="cons_acq_mutex">
          <mxGeometry relative="1" as="geometry" />
