          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_buffer_rem" target="cons_rel_mutex">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="cons_rel_mutex" target="res_mutex_inc_cons">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- After releasing mutex, we release semVazio, then sleep, then loop back -->
        <mxCell id="cons_rel_vazio" value="Sinalizar Vaga Liberada&#xa;(semVazio.release())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_consumidor">
          <mxGeometry x="60" y="960" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="res_vazio_inc" value="Incrementar semVazio&#xa;(Acorda Produtor bloqueado)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="960" width="180" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_sleep" value="Consumir Item &amp; Dormir&#xa;(Thread.sleep(2000))" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_consumidor">
          <mxGeometry x="60" y="1040" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="ec9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_mutex_inc_cons" target="cons_rel_vazio">
