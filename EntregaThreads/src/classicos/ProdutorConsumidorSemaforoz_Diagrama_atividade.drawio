        <mxCell id="ep5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="prod_acq_mutex" target="res_mutex_dec_prod">
          <mxGeometry relative="1" as="geometry" />
