<mxfile host="app.diagrams.net" pages="1">
  <diagram id="produtor_consumidor_semaforo_activity" name="Activity Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Parent Swimlane Container -->
        <mxCell id="swimlanes" value="Produtor-Consumidor com Semáforos" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="860" height="960" as="geometry" />
        </mxCell>
        
        <!-- Lane 1: Thread Produtor -->
        <mxCell id="lane_produtor" value="Thread Produtor (Produtor)" style="swimlane;startSize=20;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="270" height="940" as="geometry" />
        </mxCell>
        
        <!-- Lane 2: Recursos (Semaforos & Buffer) -->
        <mxCell id="lane_recursos" value="Recursos Compartilhados (Semáforos / Buffer)" style="swimlane;startSize=20;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="swimlanes" vertex="1">
          <mxGeometry x="290" y="20" width="300" height="940" as="geometry" />
        </mxCell>
        
        <!-- Lane 3: Thread Consumidor -->
        <mxCell id="lane_consumidor" value="Thread Consumidor (Consumidor)" style="swimlane;startSize=20;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="swimlanes" vertex="1">
          <mxGeometry x="590" y="20" width="270" height="940" as="geometry" />
        </mxCell>

        <!-- PRODUTOR FLOW -->
        <mxCell id="prod_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_produtor">
          <mxGeometry x="120" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="prod_item" value="Produzir Item&#xa;(item = ++item)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_produtor">
          <mxGeometry x="60" y="90" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="prod_acq_vazio" value="Solicitar Vaga&#xa;(semVazio.acquire())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_produtor">
          <mxGeometry x="60" y="160" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="prod_acq_mutex" value="Adquirir Exclusão Mútua&#xa;(mutex.acquire())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_produtor">
          <mxGeometry x="60" y="240" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="prod_insert" value="Inserir no Buffer&#xa;(buffer.add(item))" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_produtor">
          <mxGeometry x="60" y="320" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="prod_rel_mutex" value="Liberar Exclusão Mútua&#xa;(mutex.release())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_produtor">
          <mxGeometry x="60" y="400" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="prod_rel_cheio" value="Sinalizar Novo Item&#xa;(semCheio.release())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_produtor">
          <mxGeometry x="60" y="480" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="prod_sleep" value="Dormir 1000ms&#xa;(Thread.sleep(1000))" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_produtor">
          <mxGeometry x="60" y="560" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- RECURSOS ACTIONS -->
        <mxCell id="res_vazio_dec" value="Decrementar semVazio&#xa;(Bloqueia se semVazio &lt;= 0)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="160" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="res_mutex_dec_prod" value="Decrementar mutex&#xa;(Bloqueia se mutex &lt;= 0)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="240" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="res_buffer_add" value="Armazenar no Buffer&#xa;(Elemento adicionado)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="320" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="res_mutex_inc_prod" value="Incrementar mutex&#xa;(Libera uma thread da fila)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="400" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="res_cheio_inc" value="Incrementar semCheio&#xa;(Acorda Consumidor bloqueado)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="480" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="res_cheio_dec" value="Decrementar semCheio&#xa;(Bloqueia se semCheio &lt;= 0)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="640" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="res_mutex_dec_cons" value="Decrementar mutex&#xa;(Bloqueia se mutex &lt;= 0)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="720" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="res_buffer_rem" value="Remover do Buffer&#xa;(Elemento retirado)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="800" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="res_mutex_inc_cons" value="Incrementar mutex&#xa;(Libera uma thread da fila)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_recursos">
          <mxGeometry x="60" y="880" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- CONSUMIDOR FLOW -->
        <mxCell id="cons_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_consumidor">
          <mxGeometry x="120" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="cons_acq_cheio" value="Aguardar Item&#xa;(semCheio.acquire())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_consumidor">
          <mxGeometry x="60" y="640" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="cons_acq_mutex" value="Adquirir Exclusão Mútua&#xa;(mutex.acquire())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_consumidor">
          <mxGeometry x="60" y="720" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="cons_remove" value="Remover do Buffer&#xa;(item = buffer.poll())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_consumidor">
          <mxGeometry x="60" y="800" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="cons_rel_mutex" value="Liberar Exclusão Mútua&#xa;(mutex.release())" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_consumidor">
          <mxGeometry x="60" y="880" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- EDGES (Parent: 1) -->
        
        <!-- Produtor Transitions -->
        <mxCell id="ep1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="prod_start" target="prod_item">
          <mxGeometry relative="1" as="geometry" />
