        <mxCell id="ep2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="prod_item" target="prod_acq_vazio">
          <mxGeometry relative="1" as="geometry" />
