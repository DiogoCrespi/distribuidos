        </mxCell>
        <mxCell id="ec10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="cons_rel_vazio" target="res_vazio_inc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_vazio_inc" target="cons_sleep">
          <mxGeometry relative="1" as="geometry" />
