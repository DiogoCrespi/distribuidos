        <mxCell id="ep4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="res_vazio_dec" target="prod_acq_mutex">
          <mxGeometry relative="1" as="geometry" />
