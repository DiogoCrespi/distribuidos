<mxfile host="app.diagrams.net" pages="1">
  <diagram id="contas_bancarias_activity" name="Activity Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Parent Swimlane Container -->
        <mxCell id="swimlanes" value="Exclusão Mútua e Prevenção de Deadlock em Transferências" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="850" height="1100" as="geometry" />
        </mxCell>
        
        <!-- Lane 1: Thread de Transação -->
        <mxCell id="lane_transacao" value="Thread de Transação (transferir)" style="swimlane;startSize=20;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="270" height="1080" as="geometry" />
        </mxCell>
        
        <!-- Lane 2: Monitor Conta Primeira -->
        <mxCell id="lane_primeira" value="Monitor Conta Primeira (primeira)" style="swimlane;startSize=20;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="swimlanes" vertex="1">
          <mxGeometry x="290" y="20" width="270" height="1080" as="geometry" />
        </mxCell>
        
        <!-- Lane 3: Monitor Conta Segunda -->
        <mxCell id="lane_segunda" value="Monitor Conta Segunda (segunda)" style="swimlane;startSize=20;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="swimlanes" vertex="1">
          <mxGeometry x="560" y="20" width="270" height="1080" as="geometry" />
        </mxCell>

        <!-- TRANSACTION FLOW -->
        <mxCell id="tx_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_transacao">
          <mxGeometry x="120" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="tx_compare" value="Comparar nomes das contas&#xa;(this.nome.compareTo(destino.nome))" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="35" y="90" width="200" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_order" value="Origem &lt;&#xa;Destino?" style="rhombus;" vertex="1" parent="lane_transacao">
          <mxGeometry x="100" y="160" width="70" height="70" as="geometry" />
        </mxCell>

        <mxCell id="set_primeira_a" value="primeira = Origem&#xa;segunda = Destino" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="10" y="260" width="110" height="40" as="geometry" />
        </mxCell>

        <mxCell id="set_primeira_b" value="primeira = Destino&#xa;segunda = Origem" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="150" y="260" width="110" height="40" as="geometry" />
        </mxCell>

        <mxCell id="merge_order" value="" style="rhombus;" vertex="1" parent="lane_transacao">
          <mxGeometry x="120" y="330" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="tx_req_primeira" value="Solicitar Lock primeira&#xa;(synchronized(primeira))" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="45" y="390" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="tx_req_segunda" value="Solicitar Lock segunda&#xa;(synchronized(segunda))" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="45" y="490" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="tx_check_saldo" value="Verificar Saldo&#xa;(this.saldo &gt;= valor)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="45" y="590" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_saldo" value="Saldo&#xa;Suficiente?" style="rhombus;" vertex="1" parent="lane_transacao">
          <mxGeometry x="100" y="660" width="70" height="70" as="geometry" />
        </mxCell>

        <mxCell id="tx_perform" value="Atualizar Saldos&#xa;(this.saldo -= valor;&#xa;destino.saldo += valor;)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="10" y="760" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="tx_fail" value="Falhar Operação&#xa;(Retornar erro)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="140" y="760" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="merge_saldo" value="" style="rhombus;" vertex="1" parent="lane_transacao">
          <mxGeometry x="120" y="840" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="tx_rel_segunda" value="Sair do synchronized&#xa;(segunda)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="45" y="900" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="tx_rel_primeira" value="Sair do synchronized&#xa;(primeira)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_transacao">
          <mxGeometry x="45" y="1000" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="tx_end" value="End" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_transacao">
          <mxGeometry x="120" y="1050" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- MONITORS ACTIONS -->
        <mxCell id="mon1_acq" value="Adquirir Lock Exclusivo&#xa;(Bloqueia outras threads)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_primeira">
          <mxGeometry x="45" y="390" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="mon1_rel" value="Liberar Lock Exclusivo&#xa;(Acorda próxima thread)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_primeira">
          <mxGeometry x="45" y="1000" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="mon2_acq" value="Adquirir Lock Exclusivo&#xa;(Bloqueia outras threads)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_segunda">
          <mxGeometry x="45" y="490" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="mon2_rel" value="Liberar Lock Exclusivo&#xa;(Acorda próxima thread)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_segunda">
          <mxGeometry x="45" y="900" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- EDGES WITH parent="1" -->
        
        <!-- Order comparison transitions -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_start" target="tx_compare">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_compare" target="dec_order">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_order" target="set_primeira_a" value="Sim">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="110" y="240" />
              <mxPoint x="110" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_order" target="set_primeira_b" value="Não">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="240" />
              <mxPoint x="200" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="set_primeira_a" target="merge_order">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="110" y="320" />
              <mxPoint x="175" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="set_primeira_b" target="merge_order">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="250" y="320" />
              <mxPoint x="175" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="merge_order" target="tx_req_primeira">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Lock Primeira transitions -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_req_primeira" target="mon1_acq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="mon1_acq" target="tx_req_segunda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Lock Segunda transitions -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_req_segunda" target="mon2_acq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="mon2_acq" target="tx_check_saldo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Business logic & Saldo transitions -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_check_saldo" target="dec_saldo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_saldo" target="tx_perform" value="Sim">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="110" y="740" />
              <mxPoint x="110" y="780" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_saldo" target="tx_fail" value="Não">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="740" />
              <mxPoint x="200" y="780" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_perform" target="merge_saldo">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="110" y="830" />
              <mxPoint x="175" y="830" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_fail" target="merge_saldo">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="240" y="830" />
              <mxPoint x="175" y="830" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="merge_saldo" target="tx_rel_segunda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Unlock Segunda transitions -->
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_rel_segunda" target="mon2_rel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="mon2_rel" target="tx_rel_primeira">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Unlock Primeira transitions -->
        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="tx_rel_primeira" target="mon1_rel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e21" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="mon1_rel" target="tx_end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
