<mxfile host="app.diagrams.net" pages="1">
  <diagram id="produtor_consumidor_semaforo_collaboration" name="Collaboration Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="co Produtor Consumidor (Semaforo - Diagrama de Colaboração)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=410;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1000" height="730" as="geometry" />
        </mxCell>

        <!-- Objects (Nodes) -->
        
        <!-- produtor : Thread (Active Object) -->
        <mxCell id="obj_produtor" value="&lt;u&gt;produtor : Produtor&lt;/u&gt;" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="340" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- semVazio : Semaphore (Passive Object - semaphore) -->
        <mxCell id="obj_sem_vazio" value="&lt;u&gt;semVazio : Semaphore&lt;/u&gt;&lt;br&gt;(inicia em 5)" style="whiteSpace=wrap;html=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="465" y="100" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- mutex : Semaphore (Passive Object - mutex semaphore) -->
        <mxCell id="obj_mutex" value="&lt;u&gt;mutex : Semaphore&lt;/u&gt;&lt;br&gt;(inicia em 1)" style="whiteSpace=wrap;html=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="465" y="240" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- buffer : Queue (Passive Object - shared buffer) -->
        <mxCell id="obj_buffer" value="&lt;u&gt;buffer : Queue&lt;/u&gt;" style="whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="465" y="380" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- semCheio : Semaphore (Passive Object - semaphore) -->
        <mxCell id="obj_sem_cheio" value="&lt;u&gt;semCheio : Semaphore&lt;/u&gt;&lt;br&gt;(inicia em 0)" style="whiteSpace=wrap;html=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="465" y="520" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- consumidor : Thread (Active Object) -->
        <mxCell id="obj_consumidor" value="&lt;u&gt;consumidor : Consumidor&lt;/u&gt;" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="340" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Note Box: Concurrency & Semaphores notes -->
        <mxCell id="note_concurrency" value="&lt;b&gt;Produtor-Consumidor via Semáforos:&lt;/b&gt;&lt;br&gt;- &lt;b&gt;produtor e consumidor:&lt;/b&gt; Threads ativas (Active Objects) concorrentes.&lt;br&gt;- &lt;b&gt;semVazio (inicia em 5):&lt;/b&gt; Semáforo contador de espaços disponíveis para produção. Bloqueia se o buffer estiver cheio.&lt;br&gt;- &lt;b&gt;semCheio (inicia em 0):&lt;/b&gt; Semáforo contador de itens prontos para consumo. Bloqueia se o buffer estiver vazio.&lt;br&gt;- &lt;b&gt;mutex (inicia em 1):&lt;/b&gt; Semáforo binário que garante a exclusão mútua ao manipular a fila (buffer).&lt;br&gt;- &lt;b&gt;buffer (Queue):&lt;/b&gt; Recurso passivo crítico onde os itens são adicionados/removidos." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="600" width="450" height="110" as="geometry" />
        </mxCell>

        <!-- Legend Box -->
        <mxCell id="note_legend" value="&lt;b&gt;Legenda de Cores e Símbolos:&lt;/b&gt;&lt;br&gt;- &lt;font color=&quot;#d79b00&quot;&gt;&lt;b&gt;Laranja:&lt;/b&gt;&lt;/font&gt; Classes Ativas (Threads Produtor e Consumidor)&lt;br&gt;- &lt;font color=&quot;#9673a6&quot;&gt;&lt;b&gt;Lilás:&lt;/b&gt;&lt;/font&gt; Semáforos (semVazio, semCheio, mutex)&lt;br&gt;- &lt;font color=&quot;#6c8ebf&quot;&gt;&lt;b&gt;Azul:&lt;/b&gt;&lt;/font&gt; Estrutura de Buffer (Queue)&lt;br&gt;- &lt;b&gt;Setas Diagonais (↗ ↙ ↘ ↖):&lt;/b&gt; Sentido das mensagens nos links.&lt;br&gt;- &lt;b&gt;[bloqueia]:&lt;/b&gt; Indica suspensão da thread ao tentar dar acquire()." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="600" width="370" height="110" as="geometry" />
        </mxCell>

        <!-- Edges (Links with Messages) -->

        <!-- Link 1: produtor to semVazio (acquire, return) -->
        <mxCell id="edge_p_sem_vazio" edge="1" parent="1" source="obj_produtor" target="obj_sem_vazio" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_p_sem_vazio" connectable="0" parent="edge_p_sem_vazio" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="1, 12: acquire() ↗&lt;br&gt;[retorno] ↙" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-30" y="-15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 2: produtor to mutex (acquire, release, return) -->
        <mxCell id="edge_p_mutex" edge="1" parent="1" source="obj_produtor" target="obj_mutex" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_p_mutex" connectable="0" parent="edge_p_mutex" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="2, 13: acquire() ↗&lt;br&gt;4, 15: release() ↗&lt;br&gt;[retorno] ↙" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-35" y="-10" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 3: produtor to buffer (add, return) -->
        <mxCell id="edge_p_buffer" edge="1" parent="1" source="obj_produtor" target="obj_buffer" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_p_buffer" connectable="0" parent="edge_p_buffer" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="3: add(1) ➔&lt;br&gt;14: add(2) ➔&lt;br&gt;[retorno] ←" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-35" y="15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 4: produtor to semCheio (release, return) -->
        <mxCell id="edge_p_sem_cheio" edge="1" parent="1" source="obj_produtor" target="obj_sem_cheio" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_p_sem_cheio" connectable="0" parent="edge_p_sem_cheio" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="5, 16: release() ↘&lt;br&gt;[retorno] ↖" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-30" y="20" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 5: consumidor to semCheio (acquire, block, return) -->
        <mxCell id="edge_c_sem_cheio" edge="1" parent="1" source="obj_consumidor" target="obj_sem_cheio" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#82b366;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_c_sem_cheio" connectable="0" parent="edge_c_sem_cheio" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="6, 11: acquire() ↙&lt;br&gt;[retorno] ↗" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="30" y="20" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 6: consumidor to mutex (acquire, release, return) -->
        <mxCell id="edge_c_mutex" edge="1" parent="1" source="obj_consumidor" target="obj_mutex" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#82b366;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_c_mutex" connectable="0" parent="edge_c_mutex" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="7, 17: acquire() ↖&lt;br&gt;9, 19: release() ↖&lt;br&gt;[retorno] ↘" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="35" y="-10" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 7: consumidor to buffer (poll, return item) -->
        <mxCell id="edge_c_buffer" edge="1" parent="1" source="obj_consumidor" target="obj_buffer" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#82b366;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_c_buffer" connectable="0" parent="edge_c_buffer" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="8, 18: poll() ←&lt;br&gt;[retorno] (item) ➔" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="35" y="15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 8: consumidor to semVazio (release, return) -->
        <mxCell id="edge_c_sem_vazio" edge="1" parent="1" source="obj_consumidor" target="obj_sem_vazio" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#82b366;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_c_sem_vazio" connectable="0" parent="edge_c_sem_vazio" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="10, 20: release() ↖&lt;br&gt;[retorno] ↘" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="30" y="-15" as="offset" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
