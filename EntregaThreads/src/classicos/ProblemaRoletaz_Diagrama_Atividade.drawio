<mxfile host="app.diagrams.net" pages="1">
  <diagram id="roletas_activity" name="Activity Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Swimlanes for Roleta Thread and Lock Monitor -->
        <mxCell id="swimlanes" value="Exclusão Mútua de Roletas" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="760" height="740" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_roleta" value="Thread de Roleta (Roleta)" style="swimlane;startSize=20;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="370" height="720" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_monitor" value="Monitor (lock:Object)" style="swimlane;startSize=20;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="swimlanes" vertex="1">
          <mxGeometry x="390" y="20" width="370" height="720" as="geometry" />
        </mxCell>

        <!-- ROLETA FLOW -->
        <mxCell id="act_start" value="Start" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="lane_roleta">
          <mxGeometry x="170" y="30" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="act_init_loop" value="j = 0" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_roleta">
          <mxGeometry x="135" y="90" width="100" height="40" as="geometry" />
        </mxCell>

        <mxCell id="dec_loop_cond" value="j &lt; girosPorRoleta?" style="rhombus;" vertex="1" parent="lane_roleta">
          <mxGeometry x="110" y="160" width="150" height="50" as="geometry" />
        </mxCell>

        <mxCell id="act_lock_req" value="Tentar entrar no bloco&#xa;(synchronized(lock))" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_roleta">
          <mxGeometry x="95" y="230" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_entered" value="Entrar no bloco crítico" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_roleta">
          <mxGeometry x="110" y="380" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_inc_counter" value="Incrementar contador&#xa;(contadorGlobal++)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_roleta">
          <mxGeometry x="110" y="450" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_unlock_req" value="Sair do synchronized" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_roleta">
          <mxGeometry x="110" y="520" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_inc_j" value="j = j + 1" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_roleta">
          <mxGeometry x="135" y="600" width="100" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_end" value="End" style="ellipse;html=1;shape=endState;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_roleta">
          <mxGeometry x="170" y="670" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- MONITOR FLOW -->
        <mxCell id="act_lock_acq" value="Adquirir lock exclusivo&#xa;(bloqueia outras threads)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_monitor">
          <mxGeometry x="95" y="300" width="180" height="40" as="geometry" />
        </mxCell>

        <mxCell id="act_lock_rel" value="Liberar lock exclusivo&#xa;(acorda próxima thread)" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_monitor">
          <mxGeometry x="95" y="520" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- EDGES WITH parent="1" -->

        <!-- Transitions -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_start" target="act_init_loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_init_loop" target="dec_loop_cond">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_loop_cond" target="act_lock_req" value="Sim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="dec_loop_cond" target="act_end" value="Não">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="185" />
              <mxPoint x="320" y="650" />
              <mxPoint x="185" y="650" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_lock_req" target="act_lock_acq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_lock_acq" target="act_entered">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_entered" target="act_inc_counter">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_inc_counter" target="act_unlock_req">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_unlock_req" target="act_lock_rel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="act_lock_rel" target="act_inc_j">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="act_inc_j" target="dec_loop_cond">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="620" />
              <mxPoint x="80" y="185" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>