<mxfile host="app.diagrams.net" pages="1">
  <diagram id="contas_bancarias_collaboration" name="Collaboration Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="co Prevenção de Deadlock em ContasBancarias (Diagrama de Colaboração)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=450;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1000" height="700" as="geometry" />
        </mxCell>

        <!-- Objects (Nodes) -->
        
        <!-- t1:Thread (Active Object) -->
        <mxCell id="obj_t1" value="&lt;u&gt;t1:Thread&lt;/u&gt;&lt;br&gt;(Transf A-&gt;B)" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="230" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- t2:Thread (Active Object) -->
        <mxCell id="obj_t2" value="&lt;u&gt;t2:Thread&lt;/u&gt;&lt;br&gt;(Transf B-&gt;A)" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="230" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- contaA:Conta (Passive Object - lock Primeira) -->
        <mxCell id="obj_contaA" value="&lt;u&gt;contaA : Conta&lt;/u&gt;&lt;br&gt;(lock Primeira)" style="whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="100" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- contaB:Conta (Passive Object - lock Segunda) -->
        <mxCell id="obj_contaB" value="&lt;u&gt;contaB : Conta&lt;/u&gt;&lt;br&gt;(lock Segunda)" style="whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="360" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Note Box: Concurrency & Deadlock Prevention notes -->
        <mxCell id="note_concurrency" value="&lt;b&gt;Prevenção de Deadlock em Contas Bancárias:&lt;/b&gt;&lt;br&gt;- &lt;b&gt;t1 e t2:&lt;/b&gt; Threads ativas concorrentes que realizam transferências entre as contas A e B em sentidos opostos.&lt;br&gt;- &lt;b&gt;contaA e contaB:&lt;/b&gt; Objetos passivos (contas) compartilhados que atuam como recursos com travas individuais (Monitores).&lt;br&gt;- &lt;b&gt;Prevenção de Deadlock:&lt;/b&gt; Para evitar o abraço mortal (deadlock), os locks são adquiridos sempre em ordem alfabética do nome da conta (&lt;i&gt;Conta-A&lt;/i&gt; primeiro, depois &lt;i&gt;Conta-B&lt;/i&gt;).&lt;br&gt;- &lt;b&gt;Efeito Prático:&lt;/b&gt; A thread &lt;i&gt;t2&lt;/i&gt; tenta adquirir o lock da &lt;i&gt;Conta-A&lt;/i&gt; primeiro (mesmo transferindo de B para A), bloqueando e aguardando &lt;i&gt;t1&lt;/i&gt; liberar, eliminando a espera circular." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="450" height="180" as="geometry" />
        </mxCell>

        <!-- Legend Box -->
        <mxCell id="note_legend" value="&lt;b&gt;Legenda de Cores e Símbolos:&lt;/b&gt;&lt;br&gt;- &lt;font color=&quot;#d79b00&quot;&gt;&lt;b&gt;Laranja:&lt;/b&gt;&lt;/font&gt; Classes Ativas (Threads de Transferência)&lt;br&gt;- &lt;font color=&quot;#6c8ebf&quot;&gt;&lt;b&gt;Azul:&lt;/b&gt;&lt;/font&gt; Classes Passivas (Recursos Compartilhados)&lt;br&gt;- &lt;b&gt;Setas Diagonais (↗ ↙ ↘ ↖):&lt;/b&gt; Indicam o sentido do fluxo das mensagens ao longo dos links.&lt;br&gt;- &lt;b&gt;[bloqueado]:&lt;/b&gt; Indica tentativa de lock em recurso já travado, forçando a thread a dormir.&lt;br&gt;- &lt;b&gt;[adquirido]:&lt;/b&gt; Confirmação de travamento bem-sucedido do monitor." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="470" width="370" height="180" as="geometry" />
        </mxCell>

        <!-- Edges (Links with Messages) -->

        <!-- Link 1: t1 to contaA (transferir, lock, ops, release) -->
        <mxCell id="edge_t1_contaA" edge="1" parent="1" source="obj_t1" target="obj_contaA" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_t1_contaA" connectable="0" parent="edge_t1_contaA" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="1: transferir(contaB, 100) ↗&lt;br&gt;synchronized(contaA) [adquirido] ↙&lt;br&gt;5: saldo -= 100 / saldo += 100 ↗&lt;br&gt;release(contaA) ↙" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-20" y="-30" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 2: t1 to contaB (lock, release) -->
        <mxCell id="edge_t1_contaB" edge="1" parent="1" source="obj_t1" target="obj_contaB" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#d79b00;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_t1_contaB" connectable="0" parent="edge_t1_contaB" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="4: synchronized(contaB) [adquirido] ↘&lt;br&gt;retorno lock ↖&lt;br&gt;6: release(contaB) ↖" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="-25" y="30" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 3: t2 to contaA (lock block, lock acquire, release) -->
        <mxCell id="edge_t2_contaA" edge="1" parent="1" source="obj_t2" target="obj_contaA" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#82b366;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_t2_contaA" connectable="0" parent="edge_t2_contaA" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="3: synchronized(contaA) [bloqueado] ↖&lt;br&gt;8: synchronized(contaA) [adquirido] ↘&lt;br&gt;12: release(contaA) ↘" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="20" y="-30" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 4: t2 to contaB (transferir, lock, ops, release) -->
        <mxCell id="edge_t2_contaB" edge="1" parent="1" source="obj_t2" target="obj_contaB" style="endArrow=none;html=1;fontSize=12;strokeWidth=1.5;strokeColor=#82b366;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_t2_contaB" connectable="0" parent="edge_t2_contaB" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;" value="2: transferir(contaA, 50) ↙&lt;br&gt;9: synchronized(contaB) [adquirido] ↙&lt;br&gt;retorno lock ↗&lt;br&gt;10: saldo -= 50 / saldo += 50 ↙&lt;br&gt;11: release(contaB) ↗" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="25" y="30" as="offset" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
