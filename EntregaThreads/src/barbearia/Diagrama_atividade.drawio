  <diagram id="barbearia_activity" name="Activity Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Swimlanes for Cliente and Barbeiro -->
        <mxCell id="swimlanes" value="Simulação do Barbeiro Dorminhoco" style="swimlane;childLayout=stackLayout;resizeParent=1;resizeParentMax=0;startSize=20;html=1;horizontalStack=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="760" height="1060" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_cliente" value="Cliente (Cliente.java)" style="swimlane;startSize=20;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="swimlanes" vertex="1">
          <mxGeometry x="20" y="20" width="370" height="1040" as="geometry" />
        </mxCell>
        
        <mxCell id="lane_barbeiro" value="Barbeiro (Barbeiro.java)" style="swimlane;startSize=20;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="swimlanes" vertex="1">
          <mxGeometry x="390" y="20" width="370" height="1040" as="geometry" />
