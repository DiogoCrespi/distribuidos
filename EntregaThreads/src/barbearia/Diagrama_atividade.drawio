        </mxCell>

        <mxCell id="act_c_arrive" value="Chegar na barbearia" style="html=1;align=center;verticalAlign=top;rounded=1;absoluteArcSize=1;arcSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_cliente">
