<mxfile host="app.diagrams.net" pages="1">
  <diagram id="barbearia_sequence" name="Sequence Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="sd Barbearia (O Barbeiro Dorminhoco)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=250;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="860" height="580" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        
        <!-- Lifeline 1: Cliente -->
        <mxCell id="lifeline_cliente" value=":Cliente" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="80" y="80" width="100" height="480" as="geometry" />
        </mxCell>
        <mxCell id="act_cliente" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lifeline_cliente" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="380" as="geometry" />
        </mxCell>

        <!-- Lifeline 2: Barbeiro -->
        <mxCell id="lifeline_barbeiro" value=":Barbeiro" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="360" y="80" width="100" height="480" as="geometry" />
        </mxCell>
        <mxCell id="act_barbeiro" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lifeline_barbeiro" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="380" as="geometry" />
        </mxCell>
        <mxCell id="act_cut_sleep" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lifeline_barbeiro" vertex="1">
          <mxGeometry x="50" y="270" width="10" height="35" as="geometry" />
        </mxCell>

        <!-- Lifeline 3: Barbearia (Monitor) -->
        <mxCell id="lifeline_barbearia" value=":Barbearia" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#f5f5f5;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="660" y="80" width="100" height="480" as="geometry" />
        </mxCell>
        <mxCell id="act_barbearia" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#f5f5f5;strokeColor=#666666;" parent="lifeline_barbearia" vertex="1">
          <mxGeometry x="45" y="70" width="10" height="380" as="geometry" />
        </mxCell>

        <!-- Messages -->
        
        <!-- 1: Cliente entrarNaBarbearia() -->
        <mxCell id="msg_c_ent" value="1: entrarNaBarbearia(nome) [sentar na espera]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="135" y="150" as="sourcePoint" />
            <mxPoint x="705" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 2: Barbeiro cortarCabelo() -->
        <mxCell id="msg_b_cort" value="2: cortarCabelo() [bloqueia se fila vazia]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="415" y="180" as="sourcePoint" />
            <mxPoint x="705" y="180" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 3: Barbeiro acorda do cortarCabelo() -->
        <mxCell id="msg_b_wake" value="3: retorno (Barbeiro acorda)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="705" y="240" as="sourcePoint" />
            <mxPoint x="415" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 4: Cliente senta na cadeira de corte e notifica barbeiro pronto -->
        <mxCell id="msg_c_ready" value="4: Cliente ocupa cadeira e notifica barbeiro" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_barbearia" target="act_barbearia">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="735" y="270" />
              <mxPoint x="735" y="295" />
            </Array>
            <mxPoint x="715" y="270" as="sourcePoint" />
            <mxPoint x="715" y="295" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 5: Barbeiro realiza o corte (sleep) -->
        <mxCell id="msg_b_sleep" value="5: Cortar cabelo (sleep 1s-3s)" style="edgeStyle=orthogonalEdgeStyle;html=1;align=left;spacingLeft=2;endArrow=block;rounded=0;" edge="1" parent="1" source="act_barbeiro" target="act_cut_sleep">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="430" y="350" />
              <mxPoint x="430" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 6: Barbeiro finalizarCorte() -->
        <mxCell id="msg_b_fin" value="6: finalizarCorte() [libera barbeiro]" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="415" y="420" as="sourcePoint" />
            <mxPoint x="705" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 7: Cliente acorda e vai embora -->
        <mxCell id="msg_c_leave" value="7: retorno (Corte concluído)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="705" y="440" as="sourcePoint" />
            <mxPoint x="135" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>