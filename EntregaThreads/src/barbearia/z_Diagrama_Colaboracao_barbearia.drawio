<mxfile host="app.diagrams.net" pages="1">
  <diagram id="barbearia_collaboration" name="Collaboration Diagram">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Frame container -->
        <mxCell id="frame_container" value="co Barbearia (O Barbeiro Dorminhoco - Diagrama de Colaboração)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=410;height=30;boundedLbl=1;verticalAlign=middle;align=left;spacingLeft=5;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1000" height="650" as="geometry" />
        </mxCell>

        <!-- Objects (Nodes) -->
        
        <!-- clientes : Cliente (Multi-object representing clients collection) -->
        <mxCell id="obj_clientes" value="&lt;u&gt;clientes : Cliente&lt;/u&gt;" style="shape=umlMultiObject;whiteSpace=wrap;html=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="250" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- barbearia : Barbearia (Monitor - passive shared resource) -->
        <mxCell id="obj_barbearia" value="&lt;u&gt;barbearia : Barbearia&lt;/u&gt;" style="whiteSpace=wrap;html=1;align=center;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="250" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- barbeiro : Barbeiro (Active Object - thread) -->
        <mxCell id="obj_barbeiro" value="&lt;u&gt;barbeiro : Barbeiro&lt;/u&gt;" style="shape=umlActiveClass;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="250" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Note Box: Concurrency notes -->
        <mxCell id="note_concurrency" value="&lt;b&gt;Notas de Concorrência:&lt;/b&gt;&lt;br&gt;- &lt;b&gt;clientes:&lt;/b&gt; Coleção de Clientes (Multi-objeto). Cada cliente é gerada como uma thread ativa executando o método &lt;i&gt;entrarNaBarbearia()&lt;/i&gt;.&lt;br&gt;- &lt;b&gt;barbeiro:&lt;/b&gt; Thread ativa (Active Object) executando em loop infinito. Dorme se a barbearia estiver vazia.&lt;br&gt;- &lt;b&gt;barbearia:&lt;/b&gt; Monitor compartilhado (Recurso passivo). Sincroniza o barbeiro e os clientes usando &lt;i&gt;synchronized&lt;/i&gt;, &lt;i&gt;wait&lt;/i&gt; e &lt;i&gt;notifyAll&lt;/i&gt;.&lt;br&gt;- &lt;b&gt;Exclusão Mútua:&lt;/b&gt; Garante que apenas um cliente seja atendido por vez (variável &lt;i&gt;barbeiroOcupado&lt;/i&gt;) e respeita a ordem FIFO de chegada." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="450" height="180" as="geometry" />
        </mxCell>

        <!-- Legend Box -->
        <mxCell id="note_legend" value="&lt;b&gt;Legenda de Cores e Estereótipos:&lt;/b&gt;&lt;br&gt;- &lt;font color=&quot;#d79b00&quot;&gt;&lt;b&gt;Laranja:&lt;/b&gt;&lt;/font&gt; Classe Multi-objeto Cliente (Thread Cliente)&lt;br&gt;- &lt;font color=&quot;#82b366&quot;&gt;&lt;b&gt;Verde:&lt;/b&gt;&lt;/font&gt; Classe Ativa Barbeiro (Thread Barbeiro)&lt;br&gt;- &lt;font color=&quot;#666666&quot;&gt;&lt;b&gt;Cinza:&lt;/b&gt;&lt;/font&gt; Monitor Barbearia (Recurso Sincronizado)&lt;br&gt;- &lt;font color=&quot;#333333&quot;&gt;&lt;b&gt;Setas Sólidas:&lt;/b&gt;&lt;/font&gt; Chamadas de Métodos (Síncronas/Bloqueantes)&lt;br&gt;- &lt;font color=&quot;#666666&quot;&gt;&lt;b&gt;Setas Tracejadas:&lt;/b&gt;&lt;/font&gt; Retornos e Acordar de Threads" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="420" width="370" height="180" as="geometry" />
        </mxCell>

        <!-- Edges (Links with Messages) -->

        <!-- Link 1: Cliente to Barbearia (entrarNaBarbearia) -->
        <mxCell id="edge_c_ent" edge="1" parent="1" source="obj_clientes" target="obj_barbearia" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#d79b00;fillColor=#ffe6cc;exitX=1;exitY=0.3;entryX=0;entryY=0.3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_c_ent" connectable="0" parent="edge_c_ent" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=12;" value="1: entrarNaBarbearia(nome)" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 1 Return: Barbearia to Cliente -->
        <mxCell id="edge_c_ent_ret" edge="1" parent="1" source="obj_barbearia" target="obj_clientes" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#d79b00;fillColor=#ffe6cc;dashed=1;endArrow=open;exitX=0;exitY=0.7;entryX=1;entryY=0.7;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_c_ent_ret" connectable="0" parent="edge_c_ent_ret" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=12;" value="retorno (Corte concluído)" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 2: Barbeiro to Barbearia (cortarCabelo, finalizarCorte) -->
        <mxCell id="edge_b_calls" edge="1" parent="1" source="obj_barbeiro" target="obj_barbearia" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#82b366;fillColor=#d5e8d4;exitX=0;exitY=0.3;entryX=1;entryY=0.3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_b_calls" connectable="0" parent="edge_b_calls" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=12;" value="2: cortarCabelo()&lt;br&gt;6: finalizarCorte()" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-22" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Link 2 Return: Barbearia to Barbeiro (Barbeiro acorda) -->
        <mxCell id="edge_b_rets" edge="1" parent="1" source="obj_barbearia" target="obj_barbeiro" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;strokeWidth=1.5;strokeColor=#82b366;fillColor=#d5e8d4;dashed=1;endArrow=open;exitX=1;exitY=0.7;entryX=0;entryY=0.7;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_b_rets" connectable="0" parent="edge_b_rets" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=12;" value="retorno (Barbeiro acorda)" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- self-call: Barbearia (Cliente ocupa cadeira e notifica barbeiro) -->
        <mxCell id="edge_c_ready" edge="1" parent="1" source="obj_barbearia" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fontSize=12;startSize=8;endSize=8;strokeColor=#666666;strokeWidth=1.5;" target="obj_barbearia">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="510" y="200" />
              <mxPoint x="570" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_c_ready" connectable="0" parent="edge_c_ready" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=12;" value="4: Cliente ocupa cadeira e notifica barbeiro" vertex="1">
          <mxGeometry relative="1" x="0.0" as="geometry">
            <mxPoint x="0" y="-15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- self-call: Barbeiro (Cortar cabelo - sleep) -->
        <mxCell id="edge_b_sleep" edge="1" parent="1" source="obj_barbeiro" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontSize=12;startSize=8;endSize=8;strokeColor=#82b366;strokeWidth=1.5;" target="obj_barbeiro">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="900" y="200" />
              <mxPoint x="960" y="200" />
              <mxPoint x="960" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_b_sleep" connectable="0" parent="edge_b_sleep" style="edgeLabel;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fontSize=12;" value="5: Cortar cabelo (sleep)" vertex="1">
          <mxGeometry relative="1" x="-0.3" as="geometry">
            <mxPoint x="55" y="-12" as="offset" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
